    "other": "实用优先的 CSS 框架（写 CSS 而无需写太多 CSS）"
  },
  "colophon.technologyStack.shadcn": {
    "other": "基于 Radix UI 和 Tailwind 构建的可复用组件库"
  },
  "colophon.technologyStack.framer": {
    "other": "用于 React 的动画库"
  },
