  "brand.usage.title": {
    "other": "Et par noter"
  },
  "brand.usage.point1Title": {
    "other": "Brug dem bare"
  },
  "brand.usage.point1Text": {
    "other": "Du behøver ikke spørge om lov til at bruge badget, logoet eller linke til dette site. Bare tag dem, hotlink dem, smid dem på din hjemmeside. Jeg er ligeglad. Faktisk ville jeg blive glad."
  },
  "brand.usage.point2Title": {
    "other": "Behold badgets pixelerede stil"
  },
  "brand.usage.point2Text": {
    "other": "Hvis du bruger badget, så brug venligst 'image-rendering: pixelated' (eller 'crisp-edges' til Firefox) i din CSS. Uden det vil browsere sløre pixlerne, og det vil ligne lort. Det er pixelkunst, behandl det venligst som pixelkunst."
  },
  "brand.usage.point3Title": {
    "other": "Kreditering er rart, men valgfrit"
  },
  "brand.usage.point3Text": {
    "other": "Hvis du skriver om sitet eller bruger disse i et blogindlæg eller en artikel, ville et link tilbage være værdsat. Men hvis du bare tilføjer mit badge til din linkside, behøver du ikke gøre noget ekstra. Min HTML-snippet til badget linker allerede hertil."
  },
  "brand.usage.point4Title": {
    "other": "Lad være med at være mærkelig"
  },
  "brand.usage.point4Text": {
    "other": "Brug ikke disse til at udgive dig for at være mig, påstå at jeg støtter noget jeg ikke gør, eller få det til at se ud som om jeg er associeret med noget skummelt. Jeg stoler på, at du kender forskellen på at linke til et site du kan lide, og at lade som om du er en anden. Hvis du er i tvivl om, hvorvidt det du gør er mærkeligt, så er det det sandsynligvis."
  },
  "brand.usage.footer": {
    "other": "Det var det hele, bare brug dem med respekt, så er vi gode."
  },
  "colophon.title": {
    "other": "Kolofon"
  },
  "colophon.description": {
    "other": "Historien bag dette websted, og hvordan det blev bygget"
  },
  "colophon.siteHistory.title": {
    "other": "Webstedets Historie"
  },
  "colophon.siteHistory.content1": {
    "other": "Dette websted blev først registreret i slutningen af 2023, men designet har ændret sig meget i løbet af dets levetid. Den første version var bare et grundlæggende WordPress-websted hostet på en skizzy gratis hostingudbyder, den anden var Carrd-baseret, og den tredje var bygget med Astro."
  },
  "colophon.siteHistory.content2": {
    "other": "Denne nuværende iteration (den fjerde version) er et komplet redesign bygget fra bunden med moderne webteknologier. Hver version har været en udvikling, hvor denne seneste fokuserer på ydeevne, tilgængelighed og et mere personligt præg, der bedre repræsenterer, hvem jeg er, og hvad jeg holder af."
  },
  "colophon.technologyStack.title": {
    "other": "Teknologistak"
  },
  "colophon.technologyStack.nextjs": {
    "other": "React-framework, der muliggør serverside-rendering og statisk webstedsgenerering"
  },
  "colophon.technologyStack.react": {
    "other": "JavaScript-bibliotek til opbygning af brugergrænseflader"
  },
  "colophon.technologyStack.tailwind": {
    "other": "Utility-first CSS-framework"
  },
  "colophon.technologyStack.shadcn": {
    "other": "Genanvendeligt komponentbibliotek bygget med Radix UI og Tailwind"
  },
  "colophon.technologyStack.framer": {
    "other": "Animationsbibliotek til React"
  },
  "colophon.technologyStack.i18next": {
    "other": "Internationaliseringsframework"
  },
  "colophon.technologyStack.typescript": {
    "other": "Stærkt typet programmeringssprog, der bygger på JavaScript"
  },
  "colophon.hosting.title": {
    "other": "Hosting & Implementering"
  },
  "colophon.hosting.content1": {
    "other": "Webstedet er hostet på"
  },
  "colophon.hosting.content2": {
    "other": "som giver problemfri implementering fra GitHub, automatisk HTTPS og global CDN-distribution."
  },
  "colophon.hosting.content3": {
    "other": "Domænet administreres via"
  },
  "colophon.hosting.content4": {
    "other": "som giver yderligere sikkerheds- og ydelsesfordele."
  },
  "colophon.design.title": {
    "other": "Designfilosofi"
  },
  "colophon.design.p1": {
    "other": "Denne hjemmeside er designet med tilgængelighed og ydeevne for øje. Den fungerer uden JavaScript aktiveret, bruger semantisk HTML og respekterer dit privatliv ved ikke at bruge tracking cookies."
  },
  "colophon.design.p2": {
    "other": "Designet sigter mod en balance mellem moderne æstetik og klassisk web-enkelhed. Mørk tilstand er standard, fordi jeg holder af mine nethinder."
  },
