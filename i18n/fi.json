    "other": "Hosting & julkaisu"
  },
  "colophon.hosting.content1": {
    "other": "Sivusto on hostattu"
  },
  "colophon.hosting.content2": {
    "other": "joka tarjoaa sujuvan julkaisun GitHubista, automaattisen HTTPS:n ja globaalin CDN:n."
  },
  "colophon.hosting.content3": {
    "other": "Verkkotunnus hallinnoidaan"
  },
  "colophon.hosting.content4": {
    "other": "joka tarjoaa lisäturvaa ja suorituskykyä."
  },
  "colophon.design.title": {
    "other": "Suunnittelufilosofia"
  },
  "colophon.design.p1": {
    "other": "Tämä verkkosivusto on suunniteltu saavutettavuus ja suorituskyky mielessä. Se toimii ilman JavaScriptiä, käyttää semanttista HTML:ää ja kunnioittaa yksityisyyttäsi olemalla käyttämättä seurantaevästeitä."
  },
  "colophon.design.p2": {
    "other": "Suunnittelu pyrkii tasapainoon modernin estetiikan ja klassisen verkkosivustojen yksinkertaisuuden välillä. Tumma tila on oletuksena, koska pidän verkkokalvoistani."
  },
