  "brand.usage.title": {
    "other": "Pari huomiota"
  },
  "brand.usage.point1Title": {
    "other": "Käytä vapaasti"
  },
  "brand.usage.point1Text": {
    "other": "Sinun ei tarvitse kysyä lupaa merkin tai logon käyttämiseen tai sivustolle linkittämiseen. Ota ne, hotlinkkaa, lätkäise ne sivullesi. Ei kiinnosta. Itse asiassa olisin iloinen."
  },
  "brand.usage.point2Title": {
    "other": "Säilytä merkin pikselityyli"
  },
  "brand.usage.point2Text": {
    "other": "Jos käytät merkkiä (badge), käytä CSS:ssäsi 'image-rendering: pixelated' (tai Firefoxissa 'crisp-edges'). Ilman sitä selaimet sumentavat pikselit ja se näyttää roskalta. Se on pikselitaidetta, kohtele sitä kuten pikselitaidetta."
  },
  "brand.usage.point3Title": {
    "other": "Maininta on kiva, mutta vapaaehtoinen"
  },
  "brand.usage.point3Text": {
    "other": "Jos kirjoitat sivustosta tai käytät näitä blogikirjoituksessa tai artikkelissa, linkki takaisin olisi arvostettu. Mutta jos lisäät merkkini vain linkkisivullesi, sinun ei tarvitse tehdä mitään ylimääräistä. Merkin HTML-pätkä linkittää jo tänne."
  },
  "brand.usage.point4Title": {
    "other": "Älä sekoile"
  },
  "brand.usage.point4Text": {
    "other": "Älä käytä näitä esiintyäksesi minuna, väittääksesi minun suosittelevan jotain mitä en suosittele, tai antaaksesi ymmärtää minun liittyvän johonkin hämärään. Luotan siihen, että tiedät eron tykkäämäsi sivuston linkittämisen ja toisena esiintymisen välillä. Jos olet epävarma siitä, onko tekemisesi outoa, se todennäköisesti on."
  },
  "brand.usage.footer": {
    "other": "Siinä kaikki, käytä niitä kunnioittavasti niin olemme sujut."
  },
  "colophon.title": {
    "other": "Kolofoni"
  },
  "colophon.description": {
    "other": "Tarinani tämän sivuston takana ja miten se rakennettiin"
  },
  "colophon.siteHistory.title": {
    "other": "Sivuston historia"
  },
  "colophon.siteHistory.content1": {
    "other": "Tämä sivusto rekisteröitiin vasta loppuvuodesta 2023, mutta ulkoasu on muuttunut paljon matkan varrella. Ensimmäinen versio oli yksinkertainen WordPress-sivu ilmaisella hostingilla, toinen Carrd-pohjainen, kolmas rakennettu Astrolla. Tämä nykyinen (neljäs) on täysin uudelleen rakennettu modernilla web-tekniikalla."
  },
  "colophon.siteHistory.content2": {
    "other": "Jokainen versio on ollut kehitysaskel, ja uusin painottaa suorituskykyä, saavutettavuutta, täyttä näppäimistönavigointia ja henkilökohtaisempaa otetta, joka kuvastaa paremmin kuka olen ja mistä välitän."
  },
  "colophon.technologyStack.title": {
    "other": "Teknologiapino"
  },
  "colophon.technologyStack.nextjs": {
    "other": "React-kehys, joka mahdollistaa palvelinpuolen renderöinnin ja staattisen sivuston generoinnin"
  },
  "colophon.technologyStack.react": {
    "other": "JavaScript-kirjasto käyttöliittymien rakentamiseen"
  },
  "colophon.technologyStack.tailwind": {
    "other": "Utility-first CSS-kehys"
  },
  "colophon.technologyStack.shadcn": {
    "other": "Uudelleenkäytettävä komponenttikirjasto Radix UI:lla ja Tailwindilla"
  },
  "colophon.technologyStack.framer": {
    "other": "Animaatiokirjasto Reactille"
  },
  "colophon.technologyStack.i18next": {
    "other": "Kansainvälistämiskehys"
  },
  "colophon.technologyStack.typescript": {
    "other": "Vahvasti tyypitetty ohjelmointikieli, joka pohjautuu JavaScriptiin"
