  "brand.usage.title": {
    "other": "Några noter"
  },
  "brand.usage.point1Title": {
    "other": "Använd dem gärna"
  },
  "brand.usage.point1Text": {
    "other": "Du behöver inte be om lov för att använda badgen, loggan eller länka till sidan. Ta dem, hotlinka, släng upp dem på din sajt. Jag bryr mig inte. Faktiskt skulle jag bli glad."
  },
  "brand.usage.point2Title": {
    "other": "Behåll badgens pixliga stil"
  },
  "brand.usage.point2Text": {
    "other": "Om du använder badgen, snälla använd 'image-rendering: pixelated' (eller 'crisp-edges' för Firefox) i din CSS. Utan det kommer webbläsare göra pixlarna suddiga och det ser ut som skit. Det är pixel art, behandla det som pixel art."
  },
  "brand.usage.point3Title": {
    "other": "Erkännande är trevligt men valfritt"
  },
  "brand.usage.point3Text": {
    "other": "Om du skriver om sajten eller använder detta i ett blogginlägg, vore en länk tillbaka uppskattat. Men om du bara lägger till min badge på din länksida behöver du inte göra något extra. Min HTML-kod för badgen länkar redan hit."
  },
  "brand.usage.point4Title": {
    "other": "Gör inget konstigt"
  },
  "brand.usage.point4Text": {
    "other": "Använd inte dessa för att utge dig för att vara jag, påstå att jag stödjer något jag inte gör, eller få det att se ut som att jag är associerad med något skumt. Jag litar på att du vet skillnaden på att länka till en sida du gillar och att låtsas vara någon annan. Om du är osäker på om det du gör är konstigt, så är det förmodligen det."
  },
  "brand.usage.footer": {
    "other": "Det var allt, använd dem med respekt så är vi lugna."
  },
  "colophon.title": {
    "other": "Kolofon"
  },
  "colophon.description": {
    "other": "Historien bakom denna webbplats och hur den byggdes"
  },
  "colophon.siteHistory.title": {
    "other": "Webbplatsens historia"
  },
  "colophon.siteHistory.content1": {
    "other": "Den här webbplatsen registrerades först i slutet av 2023, men designen har ändrats mycket under dess livstid. Första versionen var en enkel WordPress-sida på ett skumt gratis webbhotell, andra var Carrd-baserad, tredje byggd med Astro. Den nuvarande versionen (fjärde) är en total omdesign byggd från grunden med moderna webtekniker."
  },
  "colophon.siteHistory.content2": {
    "other": "Varje version har varit en utveckling, där den senaste fokuserar på prestanda, tillgänglighet, fullständig tangentbordsnavigering och en mer personlig känsla som bättre representerar vem jag är och vad jag bryr mig om."
  },
  "colophon.technologyStack.title": {
    "other": "Teknikstack"
  },
  "colophon.technologyStack.nextjs": {
    "other": "React-ramverk som möjliggör server-side rendering och statisk webbplatsgenerering"
  },
  "colophon.technologyStack.react": {
    "other": "JavaScript-bibliotek för att bygga användargränssnitt"
  },
  "colophon.technologyStack.tailwind": {
    "other": "Utility-first CSS-ramverk"
  },
  "colophon.technologyStack.shadcn": {
    "other": "Återanvändbart komponentbibliotek byggt med Radix UI och Tailwind"
  },
  "colophon.technologyStack.framer": {
    "other": "Animationsbibliotek för React"
  },
  "colophon.technologyStack.i18next": {
    "other": "Internationaliseringsramverk"
  },
  "colophon.technologyStack.typescript": {
    "other": "Starkt typat programmeringsspråk som bygger på JavaScript"
  },
  "colophon.hosting.title": {
    "other": "Hosting & distribution"
  },
  "colophon.hosting.content1": {
    "other": "Sidan är hostad på"
  },
  "colophon.hosting.content2": {
    "other": "som erbjuder smidig distribution från GitHub, automatisk HTTPS och global CDN."
  },
  "colophon.hosting.content3": {
    "other": "Domänen hanteras via"
  },
  "colophon.hosting.content4": {
    "other": "som ger extra säkerhet och prestanda."
  },
  "colophon.design.title": {
    "other": "Designfilosofi"
  },
  "colophon.design.p1": {
    "other": "Denna webbplats är utformad med tillgänglighet och prestanda i åtanke. Den fungerar utan JavaScript aktiverat, använder semantisk HTML och respekterar din integritet genom att inte använda några spårningskakor."
  },
  "colophon.design.p2": {
    "other": "Designen syftar till en balans mellan modern estetik och klassisk webbenkelhet. Mörkt läge är standard eftersom jag gillar mina näthinnor."
  },
