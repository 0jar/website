  "brand.usage.point1Title": {
    "other": "o kepeken!"
  },
  "brand.usage.point1Text": {
    "other": "sina wile ala toki e 'mi ken ala ken?' tawa ni: sina kepeken sitelen mi. o kama jo e ona. o kepeken ona lon lipu sina. mi wile e ni. ni li pona tawa mi."
  },
  "brand.usage.point2Title": {
    "other": "o awen e lukin leko"
  },
  "brand.usage.point2Text": {
    "other": "sina kepeken sitelen lili la, o kepeken nasin 'image-rendering: pixelated' (anu 'crisp-edges') lon nasin CSS. sina kepeken ala e ni la, ilo li pakala e lukin leko. ona li lukin jaki. ni li sitelen leko. o lukin e ona sama sitelen leko."
  },
  "brand.usage.point3Title": {
    "other": "toki tan li pona, taso wile ala"
  },
  "brand.usage.point3Text": {
    "other": "sina sitelen e ijo pi lipu mi la, o toki e ni: lipu mi li lon. ni li pona. taso, sina pana e sitelen lili mi tawa lipu sina la, sina wile pali e ala. nasin HTML mi li jo e nasin tawa lipu mi."
  },
  "brand.usage.point4Title": {
    "other": "o nasa ala"
  },
  "brand.usage.point4Text": {
    "other": "o kepeken ala ni tawa ni: sina lukin sama mi, anu sina toki e ni: 'Jarema li olin e ni', taso mi olin ala e ona. mi pilin e ni: sina sona e ante pi 'pana e nasin tawa lipu' en 'lukin sama jan ante'. sina sona ala e ni: 'pali mi li nasa, anu seme?', la ona li nasa."
  },
  "brand.usage.footer": {
    "other": "ni taso. o kepeken pona la, ale li pona."
  },
