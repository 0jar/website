  "brand.usage.title": {
    "other": "A few notes"
  },
  "brand.usage.point1Title": {
    "other": "Feel free to use these"
  },
  "brand.usage.point1Text": {
    "other": "You don't need to ask permission to use the badge, logo, or link to this site. Grab them, hotlink them, slap them on your website. I don't care. Actually, I'd be delighted."
  },
  "brand.usage.point2Title": {
    "other": "Keep the badge's pixelated style"
  },
  "brand.usage.point2Text": {
    "other": "If you're using the badge, please use image-rendering: pixelated (or crisp-edges for Firefox) in your CSS. Without it, browsers will blur the pixels and it'll look like garbage. It's pixel art, please treat it like pixel art."
  },
  "brand.usage.point3Title": {
    "other": "Attribution is nice but optional"
  },
  "brand.usage.point3Text": {
    "other": "If you're writing about the site or using these in a blog post or article, a link back would be appreciated. But if you're just adding my badge to your links page, you don't need to do anything extra. My HTML snippet for the badge itself already links here."
  },
  "brand.usage.point4Title": {
    "other": "Don't be weird about it"
  },
  "brand.usage.point4Text": {
    "other": "Don't use these to impersonate me, claim I endorsed something I didn't, or make it look like I'm affiliated with something sketchy. I trust you know the difference between linking to a site you like and pretending to be someone else. If you're unsure whether what you're doing is weird, it probably is."
  },
  "brand.usage.footer": {
    "other": "That's it, just use them respectfully and we're good."
  },
  "colophon.title": {
    "other": "Colophon"
  },
  "colophon.description": {
    "other": "The story behind this website and how it was built"
  },
  "colophon.siteHistory.title": {
    "other": "Site history"
  },
  "colophon.siteHistory.content1": {
    "other": "This site was just registered in late 2023, yet the design has changed a lot over the span of its life. The first version was just a basic WordPress site hosted on a sketchy free hosting provider, the second was Carrd-based, and the third was built with Astro. This current iteration (the fourth version) is a complete redesign built from scratch with modern web technologies."
  },
  "colophon.siteHistory.content2": {
    "other": "Each version has been an evolution, with this latest one focusing on performance, accessibility, full keyboard navigation, and a more personal touch that better represents who I am and what I care about."
  },
  "colophon.technologyStack.title": {
    "other": "Technology stack"
  },
