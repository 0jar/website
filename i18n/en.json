    "other": "Utility-first CSS framework"
  },
  "colophon.technologyStack.shadcn": {
    "other": "Reusable component library built with Radix UI and Tailwind"
  },
  "colophon.technologyStack.framer": {
    "other": "Animation library for React"
  },
  "colophon.technologyStack.i18next": {
    "other": "Internationalization framework"
  },
  "colophon.technologyStack.typescript": {
    "other": "Strongly typed programming language that builds on JavaScript"
  },
  "colophon.hosting.title": {
    "other": "Hosting & deployment"
  },
  "colophon.hosting.content1": {
    "other": "The site is hosted on"
  },
  "colophon.hosting.content2": {
    "other": "which provides seamless deployment from GitHub, automatic HTTPS, and global CDN distribution."
  },
  "colophon.hosting.content3": {
    "other": "The domain is managed through"
  },
  "colophon.hosting.content4": {
    "other": "which provides additional security and performance benefits."
  },
  "colophon.design.title": {
    "other": "Design philosophy"
  },
  "colophon.design.p1": {
    "other": "This website is designed with accessibility and performance in mind. It works without JavaScript enabled, uses semantic HTML, and respects your privacy by not using any tracking cookies."
  },
  "colophon.design.p2": {
    "other": "The design aims for a balance between modern aesthetics and classic web simplicity. Dark mode is the default because I like my retinas."
  },
