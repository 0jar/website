  "brand.usage.title": {
    "other": "留意𡮈"
  },
  "brand.usage.point1Title": {
    "other": "Cứ thoải mái dùng"
  },
  "brand.usage.point1Text": {
    "other": "Không cần xin phép để dùng huy hiệu, logo hay dẫn link tới web này đâu. Cứ lấy, hotlink, hay vứt lên web của bạn. Mình không quan tâm. Thực ra là mình còn thấy vui ấy chứ."
  },
  "brand.usage.point2Title": {
    "other": "𡨺元 style pixel 𧵑徽號"
  },
  "brand.usage.point2Text": {
    "other": "Nếu dùng huy hiệu (badge), làm ơn thêm 'image-rendering: pixelated' (hoặc 'crisp-edges' trên Firefox) vào CSS. Không có nó, trình duyệt sẽ làm mờ pixel nhìn như rác ấy. Nó là pixel art, làm ơn hãy đối xử với nó như pixel art."
  },
  "brand.usage.point3Title": {
    "other": "Ghi nguồn thì tốt, không thì cũng không sao"
  },
  "brand.usage.point3Text": {
    "other": "Nếu bạn viết bài về trang web này hay dùng tư liệu trong blog, dẫn link lại thì mình sẽ vui lắm. Nhưng nếu chỉ gắn cái badge vào trang liên kết thì không cần làm gì thêm đâu, cái mã HTML của badge mình đưa đã có link sẵn về đây rồi."
  },
  "brand.usage.point4Title": {
    "other": "揨𫜵𠻀"
  },
  "brand.usage.point4Text": {
    "other": "Đừng dùng mấy cái này để giả danh mình, nhét chữ vào mình, hay làm như kiểu mình dính dáng tới cái gì mờ ám. Mình tin là bạn biết sự khác biệt giữa việc dẫn link tới trang bạn thích và việc giả mạo người khác. Nếu thấy lấn cấn không biết việc bạn định làm có kỳ cục không, thì khả năng cao là có đấy."
  },
  "brand.usage.footer": {
    "other": "Thế thôi, cứ dùng đàng hoàng là được."
  },
  "colophon.title": {
    "other": "通信張䇼"
  },
  "colophon.description": {
    "other": "句𡀯𱘃𢖖󠄁張䇼尼"
  },
  "colophon.siteHistory.title": {
    "other": "Lịch sử trang này"
  },
  "colophon.siteHistory.content1": {
    "other": "Mình mới đăng ký trang web này vào cuối năm 2023, nhưng thiết kế nó đã thay đổi rất nhiều trong suốt thời gian này. Phiên bản đầu tiên chỉ là một trang WordPress ở trên một cái hosting miễn phí nào đó, bản thứ hai thì là trang Carrd.co, và bản thứ ba được xây trên nền Astro. Phiên bản hiện tại là một bản mình thiết kế lại hoàn toàn mới và đập đi xây lại từ đầu."
  },
  "colophon.siteHistory.content2": {
    "other": "Mỗi phiên bản đều là một sự tiến hóa nhất định, với bản mới nhất này tập trung vào độ nhanh nhạy, khả năng tiếp cận (accessibility), khả năng điều hướng hoàn toàn bằng bàn phím, và cũng như một cảm giác \"mình\" hơn một chút, thể hiện \"mình\" tốt hơn chút."
  },
  "colophon.technologyStack.title": {
    "other": "Các nền công nghệ sử dụng"
