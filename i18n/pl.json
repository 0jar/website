  },
  "colophon.hosting.title": {
    "other": "Hosting i wdrożenie"
  },
  "colophon.hosting.content1": {
    "other": "Strona hostowana na"
  },
  "colophon.hosting.content2": {
    "other": "co zapewnia płynne wdrożenia z GitHub, automatyczny HTTPS i globalny CDN."
  },
  "colophon.hosting.content3": {
    "other": "Domena zarządzana przez"
  },
  "colophon.hosting.content4": {
    "other": "co daje dodatkowe korzyści bezpieczeństwa i wydajności."
  },
  "colophon.design.title": {
    "other": "Filozofia projektowania"
  },
  "colophon.design.p1": {
    "other": "Ta strona została zaprojektowana z myślą o dostępności i wydajności. Działa bez włączonego JavaScriptu, używa semantycznego HTML i szanuje twoją prywatność, nie używając żadnych plików cookie do śledzenia."
  },
  "colophon.design.p2": {
    "other": "Projekt dąży do równowagi między nowoczesną estetyką a klasyczną prostotą sieci. Tryb ciemny jest domyślny, bo lubię swoje siatkówki."
  },
