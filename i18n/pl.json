  "brand.usage.title": {
    "other": "Kilka uwag"
  },
  "brand.usage.point1Title": {
    "other": "Śmiało korzystaj"
  },
  "brand.usage.point1Text": {
    "other": "Nie musisz pytać o zgodę na użycie odznaki, logo czy linkowanie do tej strony. Bierz, hotlinkuj, wrzucaj na swoją stronę. Nie obchodzi mnie to. A wręcz byłoby mi miło."
  },
  "brand.usage.point2Title": {
    "other": "Zachowaj pikselowy styl odznaki"
  },
  "brand.usage.point2Text": {
    "other": "Jeśli używasz odznaki (badge), proszę dodaj 'image-rendering: pixelated' (lub 'crisp-edges' w Firefox) w swoim CSS. Bez tego przeglądarki rozmyją piksele i będzie to wyglądać jak śmieć. To pixel art, traktuj to jak pixel art."
  },
  "brand.usage.point3Title": {
    "other": "Atrybucja jest miła, ale opcjonalna"
  },
  "brand.usage.point3Text": {
    "other": "Jeśli piszesz o stronie lub używasz tych materiałów w poście na blogu, link zwrotny byłby mile widziany. Ale jeśli tylko wrzucasz moją odznakę na swoją stronę z linkami, nie musisz robić nic więcej. Mój kod HTML dla odznaki już tu linkuje."
  },
  "brand.usage.point4Title": {
    "other": "Bez dziwactw"
  },
  "brand.usage.point4Text": {
    "other": "Nie używaj tego, żeby się pode mnie podszywać, twierdzić, że popieram coś, czego nie popieram, albo sprawiać wrażenie, że jestem powiązany z czymś podejrzanym. Wierzę, że znasz różnicę między linkowaniem do strony, którą lubisz, a udawaniem kogoś innego. Jeśli nie jesteś pewien, czy to co robisz jest dziwne, to prawdopodobnie jest."
  },
  "brand.usage.footer": {
    "other": "To tyle, po prostu używaj z szacunkiem i będzie git."
  },
  "colophon.title": {
    "other": "Kolofon"
  },
  "colophon.description": {
    "other": "Historia tej strony i jak powstała"
  },
  "colophon.siteHistory.title": {
    "other": "Historia strony"
  },
  "colophon.siteHistory.content1": {
    "other": "Strona została zarejestrowana dopiero pod koniec 2023 roku, ale jej wygląd zmieniał się wielokrotnie. Pierwsza wersja to prosty WordPress na podejrzanym darmowym hostingu, druga była oparta na Carrd, trzecia powstała na Astro. Ta obecna (czwarta) to pełny redesign od zera, z użyciem nowoczesnych technologii webowych."
  },
  "colophon.siteHistory.content2": {
    "other": "Każda wersja to ewolucja, a ta najnowsza skupia się na wydajności, dostępności i bardziej osobistym podejściu, które lepiej oddaje to, kim jestem i co mnie porusza."
  },
  "colophon.technologyStack.title": {
    "other": "Stos technologiczny"
  },
