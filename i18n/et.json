  "colophon.hosting.title": {
    "other": "Majutus ja juurutamine"
  },
  "colophon.hosting.content1": {
    "other": "Sait on majutatud"
  },
  "colophon.hosting.content2": {
    "other": "mis pakub sujuvat juurutamist GitHubist, automaatset HTTPS-i ja globaalset CDN-jaotust."
  },
  "colophon.hosting.content3": {
    "other": "Domeeni hallatakse läbi"
  },
  "colophon.hosting.content4": {
    "other": "mis pakub täiendavat turvalisust ja jõudlust."
  },
  "colophon.design.title": {
    "other": "Disainifilosoofia"
  },
  "colophon.design.p1": {
    "other": "See veebileht on loodud ligipääsetavust ja jõudlust silmas pidades. See töötab ilma JavaScriptita, kasutab semantilist HTML-i ja austab teie privaatsust, vältides jälgimisküpsiseid."
  },
  "colophon.design.p2": {
    "other": "Disaini eesmärk on leida tasakaal kaasaegse esteetika ja klassikalise veebi lihtsuse vahel. Tume režiim on vaikimisi sisse lülitatud, sest mulle meeldivad mu võrkkestad."
