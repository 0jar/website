  "brand.usage.title": {
    "other": "Paar märkust"
  },
  "brand.usage.point1Title": {
    "other": "Kasuta julgelt"
  },
  "brand.usage.point1Text": {
    "other": "Sa ei pea küsima luba, et kasutada märki, logo või sellele saidile linkida. Lihtsalt võta need, hotlinki, viska oma kodulehele. Mul on ükskõik. Tegelikult oleks mul isegi hea meel."
  },
  "brand.usage.point2Title": {
    "other": "Säilita märgi piksli-stiil"
  },
  "brand.usage.point2Text": {
    "other": "Kui kasutad märki (badge), palun kasuta oma CSS-is 'image-rendering: pixelated' (või Firefoxi puhul 'crisp-edges'). Ilma selleta muudavad brauserid pikslid uduseks ja see näeb välja nagu prügi. See on pikslikunst, palun kohtle seda kui pikslikunsti."
  },
  "brand.usage.point3Title": {
    "other": "Viitamine on tore, aga vabatahtlik"
  },
  "brand.usage.point3Text": {
    "other": "Kui kirjutad sellest saidist või kasutad neid materjale blogipostituses või artiklis, oleks tagasilink teretulnud. Aga kui lisad minu märgi lihtsalt oma linkide lehele, ei pea sa midagi lisaks tegema. Märgi HTML-kood viitab juba ise siia."
  },
  "brand.usage.point4Title": {
    "other": "Ära tee midagi kahtlast"
  },
  "brand.usage.point4Text": {
    "other": "Ära kasuta neid minu teesklemiseks, väitmaks, et toetan midagi, mida ma ei toeta, või jätmaks muljet, et olen seotud millegi kahtlasega. Usun, et tead vahet lingi jagamisel saidile, mis sulle meeldib, ja kellegi teisena esinemisel. Kui sa pole kindel, kas see, mida teed, on imelik, siis tõenäoliselt ongi."
  },
  "brand.usage.footer": {
    "other": "Ongi kõik, kasuta neid lihtsalt lugupidavalt ja kõik on korras."
  },
  "colophon.title": {
    "other": "Kolofon"
  },
  "colophon.description": {
    "other": "Selle veebisaidi taga peituv lugu ja selle loomine"
  },
  "colophon.siteHistory.title": {
    "other": "Saidi ajalugu"
  },
  "colophon.siteHistory.content1": {
    "other": "This site was just registered in late 2023, yet the design has changed a lot over the span of its life. The first version was just a basic WordPress site hosted on a sketchy free hosting provider, the second was Carrd-based, and the third was built with Astro. This current iteration (the fourth version) is a complete redesign built from scratch with modern web technologies."
  },
  "colophon.siteHistory.content2": {
    "other": "Each version has been an evolution, with this latest one focusing on performance, accessibility, full keyboard navigation, and a more personal touch that better represents who I am and what I care about."
  },
  "colophon.technologyStack.title": {
    "other": "Tehnoloogiapakk"
  },
  "colophon.technologyStack.nextjs": {
    "other": "React raamistik, mis võimaldab serveripoolset renderdamist ja staatiliste saitide loomist"
