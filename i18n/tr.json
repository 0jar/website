  "brand.usage.title": {
    "other": "Birkaç not"
  },
  "brand.usage.point1Title": {
    "other": "Rahatça kullanın"
  },
  "brand.usage.point1Text": {
    "other": "Rozeti veya logoyu kullanmak ya da bu siteye link vermek için izin istemenize gerek yok. Alın, hotlink yapın, sitenize yapıştırın. Umurumda değil. Aslında, memnun bile olurum."
  },
  "brand.usage.point2Title": {
    "other": "Rozetin piksel stilini koruyun"
  },
  "brand.usage.point2Text": {
    "other": "Rozeti (badge) kullanıyorsanız, lütfen CSS'inizde 'image-rendering: pixelated' (veya Firefox için 'crisp-edges') kullanın. Bu olmazsa tarayıcılar pikselleri bulanıklaştırır ve çöp gibi görünür. Bu bir piksel sanatı, lütfen ona piksel sanatı muamelesi yapın."
  },
  "brand.usage.point3Title": {
    "other": "Atıfta bulunmak güzel ama isteğe bağlı"
  },
  "brand.usage.point3Text": {
    "other": "Site hakkında yazıyorsanız veya bunları bir blog yazısında kullanıyorsanız, bir geri bağlantı (link) makbule geçer. Ancak rozetimi sadece linkler sayfanıza ekliyorsanız, fazladan bir şey yapmanıza gerek yok. Rozet için verdiğim HTML kodu zaten buraya link veriyor."
  },
  "brand.usage.point4Title": {
    "other": "Saçmalamayın"
  },
  "brand.usage.point4Text": {
    "other": "Bunları beni taklit etmek, desteklemediğim bir şeyi destekliyormuşum gibi göstermek veya tekinsiz bir şeyle ilişkilendirmek için kullanmayın. Sevdiğiniz bir siteye link vermekle başkası gibi davranmak arasındaki farkı bildiğinize inanıyorum. Yaptığınız şeyin garip olup olmadığından emin değilseniz, muhtemelen gariptir."
  },
  "brand.usage.footer": {
    "other": "Bu kadar, sadece saygılı kullanın yeter."
  },
  "colophon.title": {
    "other": "Künye"
  },
  "colophon.description": {
    "other": "Bu web sitesinin arkasındaki hikaye ve nasıl oluşturulduğu"
  },
  "colophon.siteHistory.title": {
    "other": "Site Geçmişi"
  },
  "colophon.siteHistory.content1": {
    "other": "Bu site 2023'ün sonlarında kaydedildi, ancak tasarımı ömrü boyunca çok değişti. İlk sürüm, şüpheli bir ücretsiz barındırma sağlayıcısında barındırılan temel bir WordPress sitesiydi, ikincisi Carrd tabanlıydı ve üçüncüsü Astro ile oluşturulmuştu. Bu mevcut iterasyon (dördüncü sürüm), modern web teknolojileriyle sıfırdan oluşturulmuş eksiksiz bir yeniden tasarımdır."
  },
  "colophon.siteHistory.content2": {
    "other": "Her sürüm bir evrim olmuştur; bu en sonuncusu performans, erişilebilirlik ve kim olduğumu ve neye önem verdiğimi daha iyi temsil eden daha kişisel bir dokunuşa odaklanmaktadır."
  },
  "colophon.technologyStack.title": {
    "other": "Teknoloji Yığını"
  },
  "colophon.technologyStack.nextjs": {
    "other": "Sunucu taraflı işleme ve statik site oluşturmayı sağlayan React framework'ü"
  },
  "colophon.technologyStack.react": {
    "other": "Kullanıcı arayüzleri oluşturmak için JavaScript kütüphanesi"
  },
  "colophon.technologyStack.tailwind": {
    "other": "Yardımcı program öncelikli CSS framework'ü"
  },
  "colophon.technologyStack.shadcn": {
    "other": "Radix UI ve Tailwind ile oluşturulmuş yeniden kullanılabilir bileşen kütüphanesi"
  },
  "colophon.technologyStack.framer": {
    "other": "React için animasyon kütüphanesi"
  },
  "colophon.technologyStack.i18next": {
    "other": "Uluslararasılaştırma framework'ü"
  },
  "colophon.technologyStack.typescript": {
    "other": "JavaScript üzerine kurulu, güçlü tipli programlama dili"
  },
  "colophon.hosting.title": {
    "other": "Barındırma & Dağıtım"
  },
  "colophon.hosting.content1": {
    "other": "Site şurada barındırılıyor:"
  },
  "colophon.hosting.content2": {
    "other": "GitHub'dan sorunsuz dağıtım, otomatik HTTPS ve küresel CDN dağıtımı sağlayan."
  },
  "colophon.hosting.content3": {
    "other": "Alan adı şunun aracılığıyla yönetiliyor:"
  },
  "colophon.hosting.content4": {
    "other": "ek güvenlik ve performans avantajları sağlayan."
  },
  "colophon.design.title": {
    "other": "Tasarım felsefesi"
  },
  "colophon.design.p1": {
    "other": "Bu web sitesi erişilebilirlik ve performans göz önünde bulundurularak tasarlanmıştır. JavaScript etkinleştirilmeden çalışır, semantik HTML kullanır ve herhangi bir izleme çerezi kullanmayarak gizliliğinize saygı duyar."
  },
  "colophon.design.p2": {
    "other": "Tasarım, modern estetik ile klasik web sadeliği arasında bir dengeyi hedefler. Karanlık mod varsayılandır, çünkü retinamı seviyorum."
  },
