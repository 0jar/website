---
// Lazy CommandBar loader + keyboard navigation
---

<div id="command-bar-root"></div>

<script>
  // @ts-nocheck
  import { routes, keyboardShortcuts } from "@/lib/constants";
  import { cycleTheme } from "@/lib/utils/theme-utils";
  import { cycleLanguage, getPageLocale } from "@/i18n/client";
  import { localePath } from "@/i18n/routing";
  import { isTypingInInput } from "@/hooks";

  // Build nav shortcut map: shortcut key → route path
  const locale = getPageLocale();
  const navShortcuts = {};
  for (const [key, shortcut] of Object.entries(keyboardShortcuts)) {
    if (key in routes) {
      const routePath = routes[key];
      navShortcuts[shortcut] = localePath(locale, routePath);
    }
  }

  // Global actions shared between game and non-game pages
  const globalActions = {
    m: cycleTheme,
    y: cycleLanguage,
  };

  // Lazy CommandBar state
  let loading = false;

  // Find cat button (may render after this script)
  let catBtn = null;
  const findCatBtn = () => { catBtn = document.querySelector('button[aria-label="Refresh mood cat"]'); };
  findCatBtn();
  setTimeout(findCatBtn, 1000);

  const onKeyDown = (e) => {
    if (e.ctrlKey || e.metaKey || e.altKey) return;
    if (isTypingInInput()) return;

    const { key } = e;

    // Lazy-load CommandBar on "."
    if (key === "." && !loading) {
      e.preventDefault();
      loading = true;
      Promise.all([
        import("@/components/layout/CommandBar"),
        import("preact"),
      ]).then(([{ CommandBar }, { render, h }]) => {
        const el = document.getElementById("command-bar-root");
        if (el) render(h(CommandBar, { initialOpen: true }), el);
      }).catch(() => { loading = false; });
      return;
    }

    // Global shortcuts (theme, language)
    if (key in globalActions) {
      e.preventDefault();
      globalActions[key]();
      return;
    }

    const isGame = location.pathname.includes(routes.game2048) || location.pathname.includes(routes.tetris);

    if (isGame) {
      if (key === "h") { e.preventDefault(); location.href = "/"; }
      return;
    }

    // Nav shortcuts (non-game pages only)
    if (key in navShortcuts) {
      e.preventDefault();
      location.href = navShortcuts[key];
    } else if (key === "r" && catBtn) {
      e.preventDefault();
      catBtn.click();
    }
  };

  window.addEventListener("keydown", onKeyDown);
</script>
