---
// Footer component with badges, webring links, i18n support, and secret chapter 6 easter egg

import { footerBadges, flagColors } from "@/lib/constants";
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import T from "@/components/T.astro";
---

<footer class="w-full border-t pt-1 xl:py-0" role="contentinfo">
  <div class="container flex flex-col items-center justify-center gap-2 py-2 xl:flex-row xl:gap-1 relative">
    <div
      id="footer-tap-area"
      class="flex flex-col xl:flex-row items-center gap-2 xl:gap-1 text-sm text-muted-foreground select-none cursor-default"
    >
      <T key="footer.copyright" tag="p" />
      <span class="hidden xl:inline">•</span>
      <p class="flex items-center gap-1.5 lowercase">
        <T key="footer.madeWith" />
        <Icon name="lucide:heart" class="text-red-500 w-3 h-3" aria-hidden="true" />
        <T key="footer.andChaos" />
      </p>
    </div>

    <!-- Command bar button (desktop only) -->
    <div class="hidden xl:block absolute right-4">
      <button
        id="footer-command-bar-trigger"
        class="inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring h-8 w-8 text-muted-foreground hover:text-foreground hover:bg-accent"
        aria-label="Open command bar"
      >
        <Icon name="lucide:keyboard" class="w-4 h-4" />
      </button>
    </div>
  </div>

  <!-- Status/uptime links -->
  <div class="flex justify-center gap-2 pb-3 text-sm text-muted-foreground">
    <a href="https://stats.uptimerobot.com/r43KzDQuuC" target="_blank" rel="noopener noreferrer" class="hover:text-foreground transition-colors"><T key="footer.uptime" /></a>
    <span aria-hidden="true">•</span>
    <a href="https://jar.statuspage.io" target="_blank" rel="noopener noreferrer" class="hover:text-foreground transition-colors"><T key="footer.siteStatus" /></a>
  </div>

  <!-- Badges section -->
  <nav
    class="pt-1 flex justify-center flex-wrap gap-2 mx-auto max-w-[670px]"
    aria-label="Web badges and external links"
  >
        {footerBadges.map(({ src, alt, href }) =>
      href ? (
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={alt}
          class="focus:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background rounded transition-transform duration-200 hover:-translate-y-1"
        >
          <Image src={src} alt={alt} width={88} height={31} class="transition-all duration-200 hover:brightness-110" loading="lazy" />
        </a>
      ) : (
        <Image src={src} alt={alt} width={88} height={31} class="transition-all duration-200 hover:brightness-110 hover:-translate-y-1" loading="lazy" />
      )
    )}
  </nav>

  <!-- Site badge -->
    <a class="flex justify-center mt-2 pb-3 transition-transform duration-200 hover:-translate-y-1" href="/badges/" aria-label="View all badges">
    <Image src="/badge.png" alt="A smiling Jarema in blue headphones under the stars" width={88} height={31} class="transition-all duration-200 hover:brightness-110" loading="lazy" />
  </a>

  <!-- Pride flag stripe -->
  <svg height="15" width="100%" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" role="img" class="block w-full" preserveAspectRatio="none">
    <title>Decorative footer stripe</title>
    <rect fill={flagColors.pink} height="5" width="100%" x="0" y="0"></rect>
    <rect fill={flagColors.purple} height="5" width="100%" x="0" y="5"></rect>
    <rect fill={flagColors.blue} height="5" width="100%" x="0" y="10"></rect>
  </svg>

  <!-- Spacer -->
  <div aria-hidden="true" class="h-3"></div>
</footer>

<script is:inline>
  (function () {
    // Secret chapter 6 easter egg - tap footer 6 times to reveal
    var tapCount = 0;
    var tapTimeout = null;
    var footerTapArea = document.getElementById("footer-tap-area");
    if (footerTapArea) {
      footerTapArea.addEventListener("click", function (e) {
        if (e.target && e.target.tagName === "A") return;
        tapCount++;
        if (tapTimeout) clearTimeout(tapTimeout);
        tapTimeout = setTimeout(function () { tapCount = 0; }, 2000);
        if (tapCount === 6) {
          sessionStorage.setItem("showHiddenChapter", "true");
          if (window.location.pathname.includes("/about")) {
            document.querySelectorAll(".hidden-chapter").forEach(function (el) { el.classList.remove("hidden"); });
            var chapter6 = document.getElementById("chapter-6");
            if (chapter6) chapter6.scrollIntoView({ behavior: "smooth" });
          } else {
            window.location.href = "/about/#chapter-6";
          }
          tapCount = 0;
        }
      });
    }

    // Command bar trigger button
    var trigger = document.getElementById("footer-command-bar-trigger");
    if (trigger) {
      trigger.addEventListener("click", function () {
        window.dispatchEvent(new KeyboardEvent("keydown", { key: ".", bubbles: true, cancelable: true }));
      });
    }
  })();
</script>
