---
import { navItems, author } from "@/lib/constants";
import T from "@/components/T.astro";
import LanguageToggle from "@/components/layout/LanguageToggle.astro";
import { Image } from "astro:assets";
import { localePath, stripLocale } from "@/i18n/routing";
import SettingsMenu from "./SettingsMenu.astro";

const lang = Astro.locals?.lang || "en";
const pathname = Astro.url.pathname;
const basePath = stripLocale(pathname);
const isActive = (href: string) => href === "/" ? basePath === "/" : basePath.startsWith(href);
const navState = navItems.map((item) => ({ ...item, href: localePath(lang, item.href), active: isActive(item.href) }));

const focusBase = "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background";
const navBase = `text-sm transition-colors hover:text-primary whitespace-nowrap ${focusBase} rounded-sm`;

const iconBase = { xmlns: "http://www.w3.org/2000/svg", fill: "none", stroke: "currentColor", "stroke-width": "2", "stroke-linecap": "round" as const, "stroke-linejoin": "round" as const, viewBox: "0 0 24 24" };
---

<header class="sticky top-0 z-50 w-full border-b bg-background/80 backdrop-blur-sm">
  <div class="container flex h-16 items-center justify-between px-4">
    <div class="flex items-center gap-2 min-w-0 flex-1">
      <!-- Logo -->
      <div class="flex-shrink-0">
        <a href={localePath(lang, "/")} class={`flex items-center gap-2 transition-opacity hover:opacity-80 ${focusBase} rounded-md`} aria-label={`${author.name} - Homepage`}>
          <div class="relative size-8 overflow-hidden">
            <Image src="/favicon-128.png" alt={`${author.name}'s logo`} width={32} height={32} densities={[1.5, 2]} class="size-8" aria-hidden="true" loading="eager" fetchpriority="high" />
          </div>
          <span class="font-heading font-bold text-xl sm:inline-block">{author.displayName}</span>
        </a>
      </div>

      <!-- Desktop navigation -->
      <nav class="hidden lg:flex items-center ml-6 min-w-0" aria-label="Main navigation">
        <div class="flex items-center gap-4 lg:gap-6">
          {navState.map(({ href, key, active }) => (
            <a
              href={href}
              class:list={[navBase, active ? "text-foreground font-medium" : "text-muted-foreground"]}
              aria-current={active ? "page" : undefined}
            >
              <T key={`nav.${key}`} />
              {active && <div class="h-0.5 bg-primary mt-0.5" aria-hidden="true" />}
            </a>
          ))}
        </div>
      </nav>
    </div>

    <div class="flex items-center gap-1.5 md:gap-2 flex-shrink-0">
      <!-- Language toggle (React) -->
      <LanguageToggle transition:persist />

      <!-- Settings menu -->
      <SettingsMenu />

      <!-- Mobile hamburger menu -->
      <details class="group lg:hidden relative">
        <summary class={`p-2 rounded-md hover:bg-muted transition-colors cursor-pointer list-none [&::-webkit-details-marker]:hidden ${focusBase}`} aria-label="Toggle navigation menu">
          <svg class="group-open:hidden" {...iconBase} width="20" height="20" aria-hidden="true"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
          <svg class="hidden group-open:block" {...iconBase} width="20" height="20" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </summary>
        <nav class="absolute right-0 top-full mt-2 w-48 rounded-md border bg-background/95 backdrop-blur-sm shadow-lg py-2 z-50" aria-label="Mobile navigation">
          {navState.map(({ href, key, active }) => (
            <a
              href={href}
              class:list={[
                `block px-4 py-2 text-sm transition-colors hover:bg-muted ${focusBase}`,
                active ? "text-foreground font-medium bg-muted/50" : "text-muted-foreground",
              ]}
              aria-current={active ? "page" : undefined}
            >
              <T key={`nav.${key}`} />
            </a>
          ))}
        </nav>
      </details>
    </div>
  </div>
</header>
