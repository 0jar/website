---
import { icons, copyIcon, checkIcon } from "@/lib/constants/icons";

// Share buttons
interface Props {
  title: string;
  url: string;
}

const { title, url } = Astro.props;

const encodedTitle = encodeURIComponent(title || "Post");
const encodedUrl = encodeURIComponent(url || "");

const shareLinks = [
  { url: `https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`, label: "Share on Twitter", icon: "twitter" },
  { url: `https://bsky.app/intent/compose?text=${encodedTitle}%20${encodedUrl}`, label: "Share on Bluesky", icon: "bluesky" },
  { url: `https://threads.net/intent/post?text=${encodedTitle}%20${encodedUrl}`, label: "Share on Threads", icon: "threads" },
  { url: `https://reddit.com/submit?url=${encodedUrl}&title=${encodedTitle}`, label: "Share on Reddit", icon: "reddit" },
  { url: `https://mastodon.social/share?text=${encodedTitle}%20${encodedUrl}`, label: "Share on Mastodon", icon: "mastodon" },
  { url: `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`, label: "Share on Facebook", icon: "facebook" },
  { url: `mailto:?subject=${encodedTitle}&body=${encodedUrl}`, label: "Share via Email", icon: "mail" },
];

const btnClasses = "inline-flex items-center justify-center rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 border border-input bg-background hover:bg-accent hover:text-accent-foreground h-10 w-10 btn-share";
---

<div class="flex flex-wrap gap-2">
  <!-- Copy button - client side only -->
  <button
    id="copy-share-btn"
    data-url={url}
    class={btnClasses}
    aria-label="Copy link"
    title="Copy link"
  >
    <Fragment set:html={copyIcon} />
    <Fragment set:html={checkIcon} />
  </button>

  <!-- Share links - work without JS -->
  {shareLinks.map(({ url: shareUrl, label, icon }) => (
    <a
      href={shareUrl}
      target="_blank"
      rel="noopener noreferrer"
      class={btnClasses}
      aria-label={label}
      title={label}
    >
      <Fragment set:html={icons[icon as keyof typeof icons]} />
    </a>
  ))}
</div>

<script>
  // Copy to clipboard functionality
  const copyBtn = document.getElementById('copy-share-btn');
  if (copyBtn) {
    const url = copyBtn.getAttribute('data-url');
    const copyIcon = copyBtn.querySelector('.copy-icon');
    const checkIcon = copyBtn.querySelector('.check-icon');

    copyBtn.addEventListener('click', async () => {
      if (!url) return;

      try {
        await navigator.clipboard.writeText(url);
        copyIcon?.classList.add('hidden');
        checkIcon?.classList.remove('hidden');
        setTimeout(() => {
          copyIcon?.classList.remove('hidden');
          checkIcon?.classList.add('hidden');
        }, 2000);
      } catch (err) {
        console.error('Failed to copy:', err);
      }
    });
  }
</script>
