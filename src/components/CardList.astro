---
import type { HTMLTag, Polymorphic } from 'astro/types';

type Props<Tag extends HTMLTag = 'div'> = Polymorphic<{ as: Tag }> & { cols?: 1 | 2 | 3 };
const { as: Tag = 'div', class: className, cols = 1, ...props } = Astro.props;
---

<Tag
  class:list={[
    {
      1: "flex flex-col gap-4",
      2: "grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6",
      3: "grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6"
    }[cols],
    className
  ]}
  role={(Tag === 'ul' || Tag === 'ol') ? "list" : undefined}
  {...props}
>
  <slot />
</Tag>
