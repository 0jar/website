---
// Guestbook page
import BaseLayout from "@/layouts/BaseLayout.astro";
import T from "@/components/T.astro";
import { author, services } from "@/lib/constants";
import { t } from "@/i18n/index";

const lang = Astro.locals?.lang || "en";
---

<BaseLayout title={t(lang, "guestbook.title")} description={t(lang, "guestbook.description")}>


  <div class="container mx-auto px-4 py-8 lg:py-12">
    <div class="max-w-3xl mx-auto">
      <header class="mb-8 text-center">
        <T key="guestbook.title" tag="h1" class="text-4xl font-bold mb-4" />
        <T key="guestbook.description" tag="p" class="text-lg text-muted-foreground" />
      </header>

      <!-- Atabook iframe -->
      <div class="border rounded-lg overflow-hidden bg-card">
        <iframe
          src={services.atabook.host}
          id="atabook"
          class="w-full min-h-[800px] border-0"
          title="Atabook Guestbook widget"
          loading="lazy"
          sandbox="allow-scripts allow-same-origin allow-forms allow-popups"
          referrerpolicy="no-referrer"
        ></iframe>
        <noscript>
          <div class="p-6 text-center">
            <p class="text-muted-foreground">
              The guestbook requires JavaScript to be enabled.
              Alternatively, you can <a href={`mailto:${author.email}`} class="text-primary hover:underline">email me</a> directly.
            </p>
          </div>
        </noscript>
      </div>

      <div class="mt-8 text-center text-sm text-muted-foreground">
        <p>
          <T key="guestbook.poweredBy" /> <a href="https://atabook.org" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline"><T key="guestbook.atabook" /></a> 💜
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
