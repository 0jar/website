---
import BaseLayout from "@/layouts/BaseLayout.astro";
import T from "@/components/ui/T.astro";
import { t } from "@/i18n/index";
import { siteUrl, socialLinks } from "@/lib/constants";
import { parseMarkdown } from "@/lib/utils/markdown";
import { messages as rawMessages } from "@/content/guestbook/guestbook";
import Card from "@/components/ui/Card.astro";

const lang = Astro.locals?.lang || "en";

const currentDomain = new URL(siteUrl).hostname;
const dtf = new Intl.DateTimeFormat(lang, { year: "numeric", month: "long", day: "numeric", hour: "2-digit", minute: "2-digit", second: "2-digit" });
const messages = rawMessages
  .map(r => ({ ...r, date: new Date(r.created_at), camefrom: r.camefrom?.includes(currentDomain) ? "" : r.camefrom }))
  .sort((a, b) => b.date.getTime() - a.date.getTime());

const inputCls = "w-full px-3 py-2 border border-input rounded-md bg-background text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50";
const mainFields = [
  { id: "name", label: t(lang, "guestbook.name"), type: "text" as const, req: true, autocomplete: "name", max: 200 },
  { id: "email", label: t(lang, "guestbook.email"), optText: t(lang, "guestbook.optionalEmail"), type: "email" as const, autocomplete: "email", max: 200 },
  { id: "website", label: t(lang, "guestbook.website"), optText: t(lang, "guestbook.optional"), type: "url" as const, placeholder: "https://", autocomplete: "url", max: 500 }
];
const extraFields = [
  { id: "social", label: t(lang, "guestbook.socialMedia"), type: "text" as const, placeholder: "@username", max: 200 },
  { id: "location", label: t(lang, "guestbook.whereAreYouFrom"), type: "text" as const, max: 200 },
  { id: "camefrom", label: t(lang, "guestbook.howDidYouGetHere"), type: "text" as const, max: 500 }
];
---

<script is:inline define:vars={{ neocitiesUrl: socialLinks.neocities }}>
  if (window.location.hostname.includes('neocities.org')) {
    window.location.replace(neocitiesUrl);
  }
</script>

<BaseLayout title={t(lang, "guestbook.title")} description={t(lang, "guestbook.description")}>
  <div class="container mx-auto px-4 py-8 lg:py-12 max-w-3xl">
    <header class="mb-8 text-center">
      <T key="guestbook.title" tag="h1" class="text-4xl font-bold mb-4" />
      <T key="guestbook.description" tag="p" class="text-lg text-muted-foreground" />
    </header>

    <Card padding="none" hover={false} class="p-6 md:p-8 mb-16">
      <form name="guestbook" action="/guestbook/success" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="space-y-4">
        {mainFields.map(f => (
          <div>
            <label for={f.id} class="block text-sm font-medium mb-1.5">
              {f.label} {f.req ? <span class="text-red-500" aria-hidden="true">*</span> : <span class="text-muted-foreground font-normal">{f.optText}</span>}
            </label>
            <input type={f.type} id={f.id} name={f.id} required={f.req} autocomplete={f.autocomplete} placeholder={f.placeholder} maxlength={f.max} class={inputCls} />
          </div>
        ))}

        <div aria-hidden="true">
          <label for="bot-field" class="block text-sm font-medium mb-1.5">
            {t(lang, "guestbook.botField")}
          </label>
          <input type="text" id="bot-field" name="bot-field" tabindex="-1" autocomplete="off" class={inputCls} />
        </div>

        <details class="group border border-input rounded-md p-4 bg-muted/20">
          <summary class="cursor-pointer text-sm font-medium hover:text-primary transition-colors select-none flex items-center">
            <span>{t(lang, "guestbook.additionalInfo")}</span>
            <span class="ml-auto text-muted-foreground text-xs opacity-70 group-open:hidden">{t(lang, "guestbook.show")}</span>
            <span class="ml-auto text-muted-foreground text-xs opacity-70 hidden group-open:inline">{t(lang, "guestbook.hide")}</span>
          </summary>
          <div class="space-y-4 pt-4 mt-2 border-t border-border">
            {extraFields.map(f => (
              <div>
                <label for={f.id} class="block text-sm font-medium mb-1.5">{f.label} <span class="text-muted-foreground font-normal">{t(lang, "guestbook.optional")}</span></label>
                <input type={f.type} id={f.id} name={f.id} placeholder={f.placeholder} maxlength={f.max} class={inputCls} />
              </div>
            ))}
          </div>
        </details>

        <div class="space-y-1.5">
          <label for="message" class="block text-sm font-medium">{t(lang, "guestbook.message")} <span class="text-red-500" aria-hidden="true">*</span></label>
          <div class="border border-input rounded-md overflow-hidden focus-within:ring-2 focus-within:ring-primary/50 focus-within:border-primary bg-background">
            <div role="tablist" class="bg-muted/30 border-b border-input flex px-2 pt-2 gap-2">
              <button type="button" role="tab" aria-selected="true" aria-controls="message" id="tab-write" class="px-3 py-1.5 text-sm font-medium border-b-2 border-primary text-foreground">{t(lang, "guestbook.write")}</button>
              <button type="button" role="tab" aria-selected="false" aria-controls="preview-container" id="tab-preview" class="px-3 py-1.5 text-sm font-medium border-b-2 border-transparent text-muted-foreground hover:text-foreground">{t(lang, "guestbook.preview")}</button>
            </div>
            <div class="p-0">
              <textarea id="message" role="tabpanel" name="message" required maxlength="10000" rows="4" class="w-full px-3 py-2 bg-transparent text-foreground placeholder:text-muted-foreground focus:outline-none resize-y min-h-[120px] block" placeholder={t(lang, "guestbook.leaveMessage")}></textarea>
              <div id="preview-container" data-empty-text={t(lang, "guestbook.nothingToPreview")} role="tabpanel" aria-live="polite" class="hidden w-full px-3 py-2 min-h-[120px] prose prose-sm dark:prose-invert max-w-none text-foreground"></div>
            </div>
          </div>
          <p class="text-xs text-muted-foreground mt-1">{t(lang, "guestbook.markdownSupported")}</p>
        </div>

        <div class="pt-2">
          <button type="submit" class="w-full sm:w-auto px-6 py-2.5 bg-primary text-primary-foreground rounded-md hover:opacity-90 transition-opacity text-sm">{t(lang, "guestbook.submit")}</button>
        </div>
      </form>
    </Card>

    <section aria-labelledby="messages-heading" class="space-y-8">
      <h2 id="messages-heading" class="text-2xl font-bold border-b border-border pb-4">{t(lang, "guestbook.messages")}</h2>
      {messages.length === 0 ? (
        <p class="text-muted-foreground italic">{t(lang, "guestbook.noMessages")}</p>
      ) : (
        <div class="space-y-6">
          {messages.map(msg => (
            <Card padding="base">
              <header class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between mb-3 border-b border-border pb-3">
                <div class="font-bold text-sm flex items-center gap-2 flex-wrap">
                  {msg.website ? <a href={msg.website} target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">{msg.name}</a> : <span>{msg.name}</span>}
                  {msg.social && <span class="text-sm font-normal text-muted-foreground bg-muted px-1.5 py-0.5 rounded">{msg.social}</span>}
                </div>
                <time class="text-sm text-muted-foreground mt-1 sm:mt-0" datetime={msg.date.toISOString()} data-date={msg.date.toISOString()}>{dtf.format(msg.date)}</time>
              </header>

              <div class="prose prose-sm dark:prose-invert max-w-none text-foreground" set:html={parseMarkdown(msg.message)}></div>

              {msg.reply && (
                <div class="mt-4 pl-4 border-l-2 border-primary bg-muted/20 p-3 rounded-r-md">
                  <div class="flex items-baseline gap-2 mb-1">
                    <div class="text-sm font-semibold text-primary">Jarema</div>
                    {msg.reply_date && (
                      <time class="text-xs text-muted-foreground" datetime={msg.reply_date} data-date={new Date(msg.reply_date).toISOString()}>
                        {dtf.format(new Date(msg.reply_date))}
                      </time>
                    )}
                  </div>
                  <div class="prose prose-sm dark:prose-invert max-w-none text-foreground" set:html={parseMarkdown(msg.reply)}></div>
                </div>
              )}

              {(msg.location || msg.camefrom) && (
                <footer class="mt-4 pt-3 border-t border-dashed border-border flex flex-wrap gap-x-6 gap-y-2 text-xs text-muted-foreground">
                  {msg.location && <div class="flex items-center gap-1.5" title="Location"><span aria-hidden="true">📍</span> <span class="sr-only">From:</span> {msg.location}</div>}
                  {msg.camefrom && <div class="flex items-center gap-1.5" title="Came from"><span aria-hidden="true">👋</span> <span class="sr-only">Via:</span> {msg.camefrom}</div>}
                </footer>
              )}
            </Card>
          ))}
        </div>
      )}
    </section>
  </div>
</BaseLayout>

<script>
  import { parseMarkdown } from "@/lib/utils/markdown";
  import { updateDateElements } from "@/lib/utils/timezone";

  function setupTabs() {
    const $ = (id: string) => document.getElementById(id);
    const [w, p, t, c] = ['tab-write', 'tab-preview', 'message', 'preview-container'].map($);

    if (!w || !p || !t || !c) return;

    const toggle = (isWrite: boolean) => {
      w.className = `px-3 py-1.5 text-sm font-medium border-b-2 ${isWrite ? 'border-primary text-foreground' : 'border-transparent text-muted-foreground hover:text-foreground'}`;
      w.setAttribute('aria-selected', String(isWrite));

      p.className = `px-3 py-1.5 text-sm font-medium border-b-2 ${!isWrite ? 'border-primary text-foreground' : 'border-transparent text-muted-foreground hover:text-foreground'}`;
      p.setAttribute('aria-selected', String(!isWrite));

      t.classList.toggle('hidden', !isWrite);
      c.classList.toggle('hidden', isWrite);
    };

    w.addEventListener('click', () => { toggle(true); t.focus(); });
    p.addEventListener('click', () => {
      toggle(false);
      c.innerHTML = parseMarkdown((t as HTMLTextAreaElement).value.trim()) || `<p class="text-muted-foreground italic">${c.dataset.emptyText}</p>`;
    });
  }

  function setupTimezones() {
    const section = document.querySelector('[aria-labelledby="messages-heading"]');
    if (section) {
      const lang = document.documentElement.lang || "en";
      const format = { year: "numeric", month: "long", day: "numeric", hour: "2-digit", minute: "2-digit", second: "2-digit" };
      updateDateElements(section, lang, format);
    }
  }

  setupTabs();
  setupTimezones();
  document.addEventListener('astro:page-load', () => {
    setupTabs();
    setupTimezones();
  });
</script>
