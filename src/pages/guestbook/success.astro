---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { t } from "@/i18n/index";

const lang = Astro.locals?.lang || "en";
---

<BaseLayout title={`Success - ${t(lang, "guestbook.title")}`} description="Guestbook submission successful.">
  <div class="container mx-auto px-4 py-16 lg:py-24 max-w-2xl text-center">
    <div class="border rounded-lg p-8 md:p-12 bg-card shadow-sm">
      <div class="text-5xl mb-6">✨</div>
      <h1 class="text-3xl font-bold mb-4">Thanks!</h1>
      <p class="text-lg text-muted-foreground mb-8">
        Your message has been successfully submitted. I'll review it and it should appear in the guestbook soon!
      </p>
      <a href="/guestbook/" class="inline-block px-6 py-2.5 bg-primary text-primary-foreground rounded-md hover:opacity-90 transition-opacity font-medium">
        Back to Guestbook
      </a>
    </div>
  </div>
</BaseLayout>
