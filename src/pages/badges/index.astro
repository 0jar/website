---
// Badges page
import BaseLayout from "@/layouts/BaseLayout.astro";
import T from "@/components/T.astro";
import { Image } from "astro:assets";
import { siteUrl, getSiteName, author } from "@/lib/constants";

import BADGES from "@/content/data/badges.json";
const badgesData = BADGES.map((b) => ({
  ...b,
  url: b.url === siteUrl ? siteUrl : b.url,
}));

const CATEGORIES = [
  "all",
  "personal",
  "friends",
  "worldview",
  "other-sites",
  "software",
  "web",
  "fun",
];

const lang = Astro.locals?.lang || "en";
const resolvedSiteName = getSiteName(lang);
---

<BaseLayout
  title={`Badges - ${resolvedSiteName}`}
  description="A collection of 88x31 badges."
>
  <div class="container mx-auto px-4 py-8 lg:py-12">
    <div class="max-w-4xl mx-auto">
      <header class="mb-8 text-center">
        <T key="badges.pageTitle" tag="h1" class="text-4xl font-bold mb-4" />
        <T
          key="badges.pageDescription"
          tag="p"
          class="text-lg text-muted-foreground"
        />
      </header>

      <!-- My badge section -->
      <section class="mb-12">
        <details class="border rounded-lg bg-card overflow-hidden">
          <summary
            class="p-4 cursor-pointer hover:bg-accent transition-colors font-semibold flex items-center gap-2"
          >
            <T key="badges.myBadgeTitle" />
          </summary>
          <div class="p-6 border-t">
            <T
              key="badges.myBadgeIntro"
              tag="p"
              class="text-sm text-muted-foreground mb-4"
            />
            <div class="text-center mb-6">
              <img
                src="/badges/badge.png"
                alt={`${author.name}'s badge`}
                width="176"
                height="62"
                class="pixelated mx-auto"
              />
            </div>
            <div class="mb-4">
              <T
                key="badges.hotlinkUrl"
                tag="p"
                class="text-xs text-muted-foreground mb-1"
              />
              <code
                class="block bg-muted p-2 rounded text-xs overflow-x-auto select-all"
                >{siteUrl}/badges/badge.png</code
              >
            </div>
            <div class="mb-4">
              <T
                key="badges.htmlCodeTitle"
                tag="p"
                class="text-xs text-muted-foreground mb-1"
              />
              <pre
                class="bg-muted p-2 rounded text-xs overflow-x-auto select-all"><code>{`<a href="${siteUrl}/">
  <img src="${siteUrl}/badges/badge.png" alt="${resolvedSiteName}" width="88" height="31" style="image-rendering: pixelated;">
</a>`}</code></pre>
            </div>
            <div
              class="text-xs text-muted-foreground space-y-1 mt-4 p-3 bg-muted/50 rounded"
            >
              <T
                key="badges.embeddingSuggestionsTitle"
                tag="p"
                class="font-medium"
              />
              <ul class="list-disc list-inside space-y-1">
                <li>
                  <T key="badges.suggestion1" />
                  <code class="bg-muted px-1 rounded"
                    >image-rendering: pixelated</code
                  >
                  <T key="badges.suggestion1b" />
                </li>
                <li>
                  <T key="badges.suggestion2" />
                  <code class="bg-muted px-1 rounded">{siteUrl}/</code>
                </li>
                <li>
                  <T key="badges.suggestion3" />
                  <code class="bg-muted px-1 rounded">176x62</code>
                  <T key="badges.suggestion3b" />
                </li>
              </ul>
            </div>
          </div>
        </details>
      </section>

      <section>
        <T
          key="badges.collectionHeading"
          tag="h2"
          class="text-2xl font-bold mb-4"
        />

        <!-- Controls -->
        <div class="flex flex-col sm:flex-row gap-4 mb-6">
          <div class="relative flex-1">
            <label for="badge-search" class="sr-only"
              ><T key="badges.search" /></label
            >
            <svg
              class="absolute left-3 top-1/2 transform -translate-y-1/2 h-4 w-4 text-muted-foreground"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
              ><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"
              ></path></svg
            >
            <input
              type="text"
              id="badge-search"
              placeholder="Search badges..."
              data-i18n-placeholder="badges.search"
              class="pl-10 w-full h-10 rounded-md border border-input bg-background px-3 py-2 text-sm"
            />
          </div>
          <select
            id="badge-category"
            class="h-10 rounded-md border border-input bg-background px-3 py-2 text-sm min-w-[150px]"
          >
            {
              CATEGORIES.map((cat) => (
                <option value={cat === "friends" ? "friend" : cat}>
                  <T key={`badges.categories.${cat}`} />
                </option>
              ))
            }
          </select>
          <div class="flex gap-2">
            <button
              id="view-verbose"
              class="view-btn h-10 px-4 rounded-md text-sm font-medium bg-muted text-muted-foreground hover:bg-muted/80"
              ><T key="badges.verboseView" /></button
            >
            <button
              id="view-badge-only"
              class="view-btn h-10 px-4 rounded-md text-sm font-medium bg-primary text-primary-foreground"
              ><T key="badges.badgeOnlyView" /></button
            >
          </div>
        </div>

        <T
          tag="p"
          id="badge-count"
          class="text-sm text-muted-foreground mb-4"
          key="badges.showingCount"
          params={{ count: badgesData.length }}
        />

        <!-- Badges container with both views -->
        <div id="badges-container" class="badge-only">
          {
            badgesData.map((badge) => {
              const isExternal = badge.url && !badge.url.startsWith("/");
              const img = (
                <Image
                  src={badge.src}
                  alt={badge.alt}
                  width={88}
                  height={31}
                  class="pixelated hover:opacity-90 transition-opacity"
                  loading="lazy"
                />
              );

              return (
                <div
                  class="badge-item"
                  data-category={badge.category}
                  data-name={badge.name.toLowerCase()}
                  data-description={badge.description.toLowerCase()}
                >
                  {badge.url ? (
                    <a
                      href={badge.url}
                      target={isExternal ? "_blank" : undefined}
                      rel={isExternal ? "noopener noreferrer" : undefined}
                      title={badge.name}
                      aria-label={badge.name}
                    >
                      {img}
                    </a>
                  ) : (
                    <span title={badge.name}>{img}</span>
                  )}
                  <div class="badge-details">
                    <h3 class="font-medium">{badge.name}</h3>
                    <p class="text-sm text-muted-foreground">
                      {badge.description}
                    </p>
                  </div>
                </div>
              );
            })
          }
        </div>

        <div id="no-results" class="hidden text-center py-12 border rounded-md">
          <T key="badges.noResults" tag="p" class="text-muted-foreground" />
        </div>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  /* Badge only view (default) */
  #badges-container.badge-only {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    padding: 1rem;
    border: 1px solid hsl(var(--border));
    border-radius: 0.5rem;
    background: hsl(var(--card));
  }

  #badges-container.badge-only .badge-details {
    display: none;
  }

  /* Verbose view */
  #badges-container.verbose {
    display: grid;
    grid-template-columns: repeat(1, minmax(0, 1fr));
    gap: 1rem;
  }

  @media (min-width: 640px) {
    #badges-container.verbose {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 768px) {
    #badges-container.verbose {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  #badges-container.verbose .badge-item {
    border: 1px solid hsl(var(--border));
    border-radius: 0.375rem;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  #badges-container.verbose .badge-item > :first-child {
    margin-bottom: 0.5rem;
    min-height: 31px;
    display: flex;
    align-items: center;
  }
</style>

<script>
  import { t } from "@/i18n/client";

  // View mode toggle
  const container = document.getElementById("badges-container")!;
  const toggleView = (isVerbose: boolean) => {
    container.className = isVerbose ? "verbose" : "badge-only";
    document.querySelectorAll(".view-btn").forEach((btn) => {
      const active = (btn.id === "view-verbose") === isVerbose;
      btn.classList.toggle("bg-primary", active);
      btn.classList.toggle("text-primary-foreground", active);
      btn.classList.toggle("bg-muted", !active);
      btn.classList.toggle("text-muted-foreground", !active);
    });
  };

  document
    .getElementById("view-verbose")
    ?.addEventListener("click", () => toggleView(true));
  document
    .getElementById("view-badge-only")
    ?.addEventListener("click", () => toggleView(false));

  // Search and filter
  const searchInput = document.getElementById(
    "badge-search",
  ) as HTMLInputElement;
  const categorySelect = document.getElementById(
    "badge-category",
  ) as HTMLSelectElement;
  const badgeCount = document.getElementById("badge-count")!;
  const noResults = document.getElementById("no-results")!;

  const filterBadges = () => {
    const query = searchInput.value.toLowerCase();
    const category = categorySelect.value;
    let visibleCount = 0;

    document.querySelectorAll(".badge-item").forEach((el) => {
      const matches =
        (category === "all" || el.getAttribute("data-category") === category) &&
        (!query ||
          el.getAttribute("data-name")!.includes(query) ||
          el.getAttribute("data-description")!.includes(query));

      (el as HTMLElement).style.display = matches ? "" : "none";
      if (matches) visibleCount++;
    });

    const total = document.querySelectorAll(".badge-item").length;
    const showingText = t("badges.showingFiltered")
      .replace("{{filtered}}", String(visibleCount))
      .replace("{{total}}", String(total));
    badgeCount.textContent =
      showingText !== "badges.showingFiltered"
        ? showingText
        : `Showing ${visibleCount} of ${total} badges`;

    container.style.display = visibleCount ? "" : "none";
    noResults.classList.toggle("hidden", visibleCount > 0);
  };

  searchInput?.addEventListener("input", filterBadges);
  categorySelect?.addEventListener("change", filterBadges);
</script>
