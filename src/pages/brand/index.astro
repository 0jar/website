---
import BaseLayout from "@/layouts/BaseLayout.astro";
import T from "@/components/ui/T.astro";
import { Image } from 'astro:assets';
import { siteUrl, getSiteName, author } from '@/lib/constants';
import Card from "@/components/ui/Card.astro";
import CardList from "@/components/ui/CardList.astro";

const lang = Astro.locals?.lang || "en";
const resolvedSiteName = getSiteName(lang);

import brandData from "@/content/data/brand.json";

const { colors, logos, fontSamples, fonts: rawFonts, usagePoints } = brandData;

const fonts = rawFonts.map(f => ({
  ...f,
  samples: ((f as any).customSamples as typeof fontSamples) || fontSamples
}));
---

<BaseLayout title="Brand" description="Visual identity and brand elements. Use these if you want to reference or link to this site.">
  <div class="container mx-auto px-4 py-8 lg:py-12 max-w-4xl">
    <header class="mb-12 text-center">
      <T key="brand.pageTitle" tag="h1" class="text-4xl font-bold mb-4" />
      <T key="brand.pageDescription" tag="p" class="text-lg text-muted-foreground mx-auto" />
    </header>

    <!-- Name -->
    <section class="mb-12">
      <T key="brand.name.title" tag="h2" class="text-2xl font-bold mb-6" />
      <Card as="div" class="space-y-4" hover={false}>
        {[["nameLabel", author.name], ["displayNameLabel", author.displayName]].map(([key, text], i) => (
          <div>
            <p class="text-sm text-muted-foreground mb-2"><T key={`brand.name.${key}`} /></p>
            <p class="text-2xl font-bold">{text}</p>
            {i === 1 && <p class="text-sm text-muted-foreground mt-2"><T key="brand.name.symbolNote" /></p>}
          </div>
        ))}
      </Card>
    </section>

    <!-- Logo -->
    <section class="mb-12">
      <T key="brand.logo.title" tag="h2" class="text-2xl font-bold mb-6" />
      <CardList cols={2}>
        {logos.map(({ key, src, alt, dimKey }) => (
          <Card as="div" hover={false}>
            <p class="text-sm font-medium mb-4"><T key={`brand.logo.${key}`} /></p>
            <div class="bg-background rounded p-8 mb-4 flex items-center justify-center">
              <Image src={`${src}.png`} alt={alt} width={128} height={128} class="pixelated" />
            </div>
            <div class="space-y-2">
              <div class="flex gap-2">
                {[{format: "png", key: "brand.logo.formats.png"}, {format: "svg", key: "brand.logo.formats.svg"}].map(({ format, key }) => (
                  <a href={`${src}.${format}`} target="_blank" class="flex-1 text-sm bg-muted hover:bg-muted/80 px-3 py-1.5 rounded text-center transition-colors"><T key={key} /></a>
                ))}
              </div>
              <p class="text-sm text-muted-foreground"><T key={`brand.logo.${dimKey}`} /></p>
            </div>
          </Card>
        ))}
      </CardList>
    </section>

    <!-- Badge -->
    <section class="mb-12">
      <T key="brand.badge.title" tag="h2" class="text-2xl font-bold mb-6" />
      <Card as="div" hover={false}>
        <div class="text-center mb-6">
          <img src="/badges/badge.png" alt={`${author.name}'s badge`} width="176" height="62" class="pixelated mx-auto" />
        </div>
        <div class="space-y-4">
          <div>
            <p class="text-sm text-muted-foreground mb-1"><T key="brand.badge.urlLabel" /></p>
            <code class="block bg-muted p-2 rounded text-sm overflow-x-auto select-all">{siteUrl}/badges/badge.png</code>
          </div>
          <div>
            <p class="text-sm text-muted-foreground mb-1"><T key="brand.badge.htmlLabel" /></p>
            <pre class="bg-muted p-2 rounded text-sm overflow-x-auto select-all"><code>{`<a href="${siteUrl}/">
  <img src="${siteUrl}/badges/badge.png" alt="${resolvedSiteName}" width="88" height="31" style="image-rendering: pixelated;">
</a>`}</code></pre>
          </div>
        </div>
      </Card>
    </section>

    <!-- Colors -->
    <section class="mb-12">
      <T key="brand.colors.title" tag="h2" class="text-2xl font-bold mb-6" />
      <CardList cols={3}>
        {colors.map(({ key, dark, light }) => (
          <Card as="div" padding="sm" hover={false}>
            <div class="mb-3">
              <T key={`brand.colors.names.${key}`} tag="p" class="font-medium mb-1" />
              <T key={`brand.colors.descriptions.${key}`} tag="p" class="text-sm text-muted-foreground" />
            </div>
            <div class="space-y-3">
              {[{ modeKey: "darkMode", data: dark }, { modeKey: "lightMode", data: light }].map(({ modeKey, data }) => (
                <div>
                  <T key={`brand.colors.${modeKey}`} tag="p" class="text-sm text-muted-foreground mb-2" />
                  <div class="flex items-center gap-2 mb-1">
                    <div class="w-8 h-8 rounded border border-border flex-shrink-0" style={`background-color: ${data.hex}`} />
                    <code class="text-sm bg-muted px-2 py-1 rounded flex-1">{data.hex}</code>
                  </div>
                  <code class="block text-sm bg-muted px-2 py-1 rounded">hsl({data.value})</code>
                </div>
              ))}
            </div>
          </Card>
        ))}
      </CardList>
    </section>

    <!-- Fonts -->
    <section class="mb-12">
      <T key="brand.fonts.title" tag="h2" class="text-2xl font-bold mb-6" />
      <CardList>
        {fonts.map(({ key, weight, link, samples, class: fontClass }) => (
          <Card as="div" hover={false}>
            <div class="mb-4 flex items-start justify-between gap-4">
              <div>
                <T key={`brand.fonts.names.${key}`} tag="h3" class="font-bold text-lg mb-1" />
                <T key={`brand.fonts.usage.${key}`} tag="p" class="text-sm text-muted-foreground mb-1" />
                <p class="text-sm text-muted-foreground"><T key="brand.fonts.weight" /> {weight}</p>
              </div>
              <a href={link} target="_blank" rel="noopener noreferrer" class="text-sm bg-muted hover:bg-muted/80 px-4 py-2 rounded transition-colors whitespace-nowrap">
                <T key="brand.fonts.viewOnGoogleFonts" />
              </a>
            </div>
            <div class="brand-font-preview bg-background rounded p-6 grid md:grid-cols-2 gap-4">
              {samples.map(({ key: langKey, text }, i) => (
                <div class:list={[i === samples.length - 1 && samples.length % 2 !== 0 && "md:col-span-2"]}>
                  <T key={`brand.fonts.languages.${langKey}`} tag="p" class="text-sm text-muted-foreground mb-1" />
                  <p class:list={["text-base", fontClass, key === "heading" && "font-bold"]}>{text}</p>
                </div>
              ))}
            </div>
          </Card>
        ))}
      </CardList>
    </section>

    <!-- Usage -->
    <section class="mb-12">
      <T key="brand.usage.title" tag="h2" class="text-2xl font-bold mb-6" />
      <Card as="div" class="space-y-4" hover={false}>
        {usagePoints.map(point => (
          <div>
            <p class="font-medium mb-2"><T key={`brand.usage.${point}Title`} /></p>
            <p class="text-sm text-muted-foreground"><T key={`brand.usage.${point}Text`} /></p>
          </div>
        ))}
      </Card>
      <p class="text-sm text-muted-foreground mt-4 text-center"><T key="brand.usage.footer" /></p>
    </section>

    <div class="text-center">
      <a href="#" class="text-sm text-muted-foreground hover:text-primary transition-colors">↑ Back to top</a>
    </div>
  </div>
</BaseLayout>
