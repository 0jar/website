---
// Contact page
import BaseLayout from "@/layouts/BaseLayout.astro";
import T from "@/components/ui/T.astro";
import { Image } from "astro:assets";

import contactData from "@/content/data/contact.json";
const { contactLinks, socialLinksData, pronounsUrls, otherLinks, qrConfigs } =
  contactData;

const svg = (d: string, size = 24) =>
  `<svg xmlns="http://www.w3.org/2000/svg" width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${d}</svg>`;

const icons: Record<string, string> = {
  mail: svg(
    '<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>',
  ),
  "message-square": svg(
    '<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>',
  ),
  phone: svg(
    '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>',
  ),
  send: svg('<path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/>'),
  calendar: svg(
    '<rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/>',
  ),
  cloud: svg('<path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/>'),
  twitter: svg(
    '<path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/>',
  ),
  "file-code": svg(
    '<path d="M4 22h14a2 2 0 0 0 2-2V7l-5-5H6a2 2 0 0 0-2 2v4"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="m5 12-3 3 3 3"/><path d="m9 18 3-3-3-3"/>',
  ),
  "at-sign": svg(
    '<circle cx="12" cy="12" r="4"/><path d="M16 8v5a3 3 0 0 0 6 0v-1a10 10 0 1 0-4 8"/>',
  ),
  image: svg(
    '<rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>',
  ),
  facebook: svg(
    '<path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>',
  ),
  user: svg(
    '<path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>',
  ),
  github: svg(
    '<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/>',
  ),
  code: svg(
    '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  ),
  globe: svg(
    '<circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/>',
  ),
  info: svg(
    '<circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/>',
    16,
  ),
  external: svg(
    '<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/>',
    16,
  ),
  key: svg(
    '<path d="m15.5 7.5 2.3 2.3a1 1 0 0 0 1.4 0l2.1-2.1a1 1 0 0 0 0-1.4L19 4"/><path d="m21 2-9.6 9.6"/><circle cx="7.5" cy="15.5" r="5.5"/>',
  ),
  shield: svg(
    '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>',
  ),
  "chevron-down": svg('<path d="m6 9 6 6 6-6"/>', 20),
};

const cardBase =
  "flex items-center justify-center gap-3 p-4 rounded-lg border transition-colors";
---

<BaseLayout title="Contact" description="Get in touch with me.">
  <div class="container mx-auto px-4 py-8 lg:py-12">
    <div class="max-w-4xl mx-auto">
      <header class="mb-10 text-center">
        <T key="contact.title" tag="h1" class="text-4xl font-bold mb-4" />
        <T
          key="contact.description"
          tag="p"
          class="text-muted-foreground text-lg"
        />
        <T key="contact.message" tag="p" class="text-lg mt-4 lowercase" />
        <T
          key="contact.disclaimer"
          tag="p"
          class="text-sm text-muted-foreground/70 mt-2 italic lowercase"
        />
      </header>

      <!-- Contact me section -->
      <section class="mb-12">
        <T
          key="contact.sectionTitles.contactMe"
          tag="h2"
          class="text-2xl font-bold mb-6"
        />
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {
            contactLinks.map(({ url, icon, name, color }) => {
              const isMail = url.startsWith("mailto:");
              return (
                <a
                  href={url}
                  target={isMail ? undefined : "_blank"}
                  rel={isMail ? undefined : "noopener noreferrer"}
                  class={`${cardBase} ${color}`}
                >
                  <span set:html={icons[icon] || icons.mail} />
                  <span class="font-medium">{name}</span>
                  {!isMail && (
                    <span class="opacity-70" set:html={icons.external} />
                  )}
                </a>
              );
            })
          }
        </div>

        <!-- QR code dropdowns -->
        {
          qrConfigs.map(({ id, name, img, desc, link, linkText }) => (
            <div id={`qr-${id}-container`} class="mt-4 hidden">
              <button
                id={`qr-${id}-toggle`}
                type="button"
                aria-expanded="false"
                aria-controls={`qr-${id}-content`}
                class="w-full flex items-center justify-center gap-2 p-3 rounded-lg border transition-colors hover:bg-muted/50"
              >
                <span set:html={icons["message-square"]} />
                <span class="font-medium">{name}</span>
                <span
                  class="transition-transform duration-200"
                  id={`${id}-chevron`}
                  set:html={icons["chevron-down"]}
                />
              </button>
              <div
                id={`qr-${id}-content`}
                class="hidden mt-2 border rounded-lg p-6 bg-card"
              >
                <div class="flex flex-col items-center text-center">
                  <Image
                    src={img}
                    alt={`${name} QR Code`}
                    width={192}
                    height={192}
                    class="w-48 h-48 object-contain mb-4"
                  />
                  <p class="text-sm text-muted-foreground">{desc}</p>
                  {link && (
                    <a
                      href={link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="mt-2 text-primary hover:underline"
                    >
                      {linkText}
                    </a>
                  )}
                </div>
              </div>
            </div>
          ))
        }
      </section>

      <!-- Keys section -->
      <section class="mb-12">
        <T
          key="contact.sectionTitles.keys"
          tag="h2"
          class="text-2xl font-bold mb-6"
        />
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <a
            href="/keys/pgp"
            target="_blank"
            rel="noopener noreferrer"
            class={`${cardBase} hover:bg-green-600 hover:text-white`}
          >
            <span set:html={icons.shield} />
            <T key="contact.links.pgpKey" tag="span" class="font-medium" />
            <span class="opacity-70" set:html={icons.external} />
          </a>
          <a
            href="/keys/ssh"
            target="_blank"
            rel="noopener noreferrer"
            class={`${cardBase} hover:bg-blue-600 hover:text-white`}
          >
            <span set:html={icons.key} />
            <T key="contact.links.sshKey" tag="span" class="font-medium" />
            <span class="opacity-70" set:html={icons.external} />
          </a>
        </div>
      </section>

      <!-- Social media section -->
      <section class="mb-12">
        <T
          key="contact.sectionTitles.socialMedia"
          tag="h2"
          class="text-2xl font-bold mb-6"
        />
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {
            socialLinksData.map(({ url, icon, name, color }) => (
              <a
                href={url}
                target="_blank"
                rel="noopener noreferrer me"
                class={`${cardBase} ${color} w-full`}
              >
                <span set:html={icons[icon] || icons["message-square"]} />
                <span class="font-medium">{name}</span>
                <span class="opacity-70" set:html={icons.external} />
              </a>
            ))
          }
        </div>
      </section>

      <!-- Other platforms section -->
      <section class="mb-12">
        <T
          key="contact.sectionTitles.otherPlatforms"
          tag="h2"
          class="text-2xl font-bold mb-6"
        />
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {
            otherLinks.map((link) =>
              link.usePronounsUrls ? (
                <a
                  id="pronouns-link"
                  href={pronounsUrls.default}
                  data-urls={JSON.stringify(pronounsUrls)}
                  target="_blank"
                  rel="noopener noreferrer"
                  class={`flex flex-col items-center justify-center gap-2 p-4 rounded-lg border transition-colors ${link.color}`}
                >
                  <div class="flex items-center gap-3">
                    <span set:html={icons[link.icon] || icons.globe} />
                    <span class="font-medium" id="pronouns-name">
                      {link.name}
                    </span>
                    <span class="opacity-70" set:html={icons.external} />
                    <span
                      class="opacity-70"
                      id="pronouns-info-icon"
                      set:html={icons.info}
                    />
                  </div>
                  <p
                    class="text-xs mt-1 md:hidden text-center opacity-80 hidden"
                    id="pronouns-note"
                  />
                </a>
              ) : (
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class={`${cardBase} ${link.color}`}
                >
                  <span set:html={icons[link.icon] || icons.globe} />
                  <span class="font-medium">{link.name}</span>
                  <span class="opacity-70" set:html={icons.external} />
                </a>
              ),
            )
          }
        </div>
      </section>
    </div>
  </div>
</BaseLayout>

<script>
  import { getPageLocale } from "@/i18n/client";

  const lang = getPageLocale();
  const qrConfigs = [
    { id: "zalo", langs: ["vi", "vi-Hani"] },
    { id: "wechat", langs: ["zh"] },
  ];

  // Setup QR toggles and visibility
  for (const { id, langs } of qrConfigs) {
    const container = document.getElementById(`qr-${id}-container`);
    if (!container) continue;

    const isVisible = langs.includes(lang);
    container.classList.toggle("hidden", !isVisible);

    if (isVisible) {
      const toggle = document.getElementById(`qr-${id}-toggle`);
      const content = document.getElementById(`qr-${id}-content`);
      const chevron = document.getElementById(`${id}-chevron`);

      toggle?.addEventListener("click", () => {
        if (!content || !chevron) return;
        const isHidden = content.classList.toggle("hidden");
        toggle.setAttribute("aria-expanded", String(!isHidden));
        chevron.style.transform = isHidden ? "rotate(0deg)" : "rotate(180deg)";
      });
    }
  }

  // Update Pronouns.page
  const pronounsLink = document.getElementById(
    "pronouns-link",
  ) as HTMLAnchorElement;
  if (pronounsLink) {
    try {
      const urls = JSON.parse(pronounsLink.dataset.urls || "{}");
      pronounsLink.href = urls[lang] || urls.default;

      if (lang === "ru") {
        const ruNote =
          "Этот сайт имеет возрастное ограничение 18+. Оставаясь на сайте, вы подтверждаете, что достигли совершеннолетия, и самостоятельно несёте ответственность за свои действия.";

        const nameEl = document.getElementById("pronouns-name");
        if (nameEl) nameEl.textContent = "Pronouns.page (18+)";

        const noteEl = document.getElementById("pronouns-note");
        if (noteEl) {
          noteEl.textContent = ruNote;
          noteEl.classList.remove("hidden");
        }

        document
          .getElementById("pronouns-info-icon")
          ?.setAttribute("title", ruNote);
      }
    } catch (e) {
      console.error("Failed to parse pronouns URLs", e);
    }
  }
</script>
