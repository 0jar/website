---
import BaseLayout from "@/layouts/BaseLayout.astro";
import T from "@/components/T.astro";
import { Image } from "astro:assets";
import { author } from '@/lib/constants';

const title = "About me";
const description = "The story of who I am, where I come from, what my passion is, and what I'm working toward.";

type ChapterConfig = {
  num: number;
  paragraphs: number;
  hidden?: boolean;
  quote?: { after: number };
  specialLastParagraph?: boolean;
};

const chapters: ChapterConfig[] = [
  { num: 1, paragraphs: 3 },
  { num: 2, paragraphs: 3 },
  { num: 3, paragraphs: 3 },
  { num: 4, paragraphs: 3, quote: { after: 2 } },
  { num: 5, paragraphs: 4 },
  { num: 6, paragraphs: 4, hidden: true, specialLastParagraph: true },
];
---

<BaseLayout title={title} description={description}>
  <div id="top" class="container mx-auto px-4 py-8 max-w-4xl">
    <header class="text-center mb-12">
      <T key="about.title" tag="h1" class="text-4xl font-bold mb-4" />
      <T key="about.description" tag="p" class="text-muted-foreground text-lg max-w-2xl mx-auto" />
    </header>

    <div class="h-card mb-10 p-6 border rounded-lg bg-muted/10 flex flex-col sm:flex-row items-center gap-4">
      <Image src="/favicon.png" alt={author.name} width={80} height={80} class="u-photo rounded-full" />
      <div class="text-center sm:text-left">
        <h2 class="p-name text-xl font-bold">{author.name}</h2>
        <p class="p-note mt-1 text-muted-foreground">{author.note}</p>
        <div class="flex flex-wrap items-center justify-center sm:justify-start gap-3 mt-2">
          <a href="/" class="u-url u-uid text-sm text-primary hover:underline">jarema.me</a>
          <a class="u-email text-sm text-primary hover:underline" href={`mailto:${author.email}`}>{author.email}</a>
        </div>
        <span class="p-category hidden">{author.category}</span>
      </div>
    </div>

    <nav class="flex flex-wrap justify-center gap-2 mb-10" aria-label="Chapter navigation">
      {chapters.map((ch) => (
        <a
          href={`#chapter-${ch.num}`}
          aria-label={`Chapter ${ch.num}`}
          class:list={[
            "px-3 py-1.5 rounded-full border text-sm hover:bg-accent transition-colors",
            ch.hidden && "hidden-chapter hidden",
          ]}
          data-hidden-chapter={ch.hidden ? "true" : undefined}
        >
          {ch.num}
        </a>
      ))}
    </nav>

    <div class="space-y-16">
      {chapters.map((ch) => (
        <section
          id={`chapter-${ch.num}`}
          class:list={["scroll-mt-20", ch.hidden && "hidden-chapter hidden"]}
        >
          <h2 class="text-2xl font-bold mb-6 text-primary">
            <span class="text-muted-foreground mr-2">{ch.num}.</span>
            <T key={`about.chapters.${ch.num}.title`} />
          </h2>
          <div class="prose-lg max-w-none space-y-4">
            {Array.from({ length: ch.paragraphs }, (_, i) => i + 1).map((i) => (
              <>
                <T
                  key={`about.chapters.${ch.num}.content${i}`}
                  tag="p"
                  class={ch.specialLastParagraph && i === ch.paragraphs
                    ? "font-medium text-foreground not-italic"
                    : undefined}
                />
                {ch.quote?.after === i && (
                  <blockquote
                    class="border-l-4 border-primary pl-4 italic my-6"
                    title={`about.chapters.${ch.num}.quoteTooltip`}
                  >
                    <T key={`about.chapters.${ch.num}.quote`} tag="p" />
                  </blockquote>
                )}
              </>
            ))}
          </div>
        </section>
      ))}
    </div>

    <div class="text-center mt-16">
      <a href="#top" class="text-sm text-muted-foreground hover:text-primary transition-colors">↑ Back to top</a>
    </div>
  </div>
</BaseLayout>

<script>
  if (sessionStorage.getItem("showHiddenChapter") === "true") {
    document.querySelectorAll(".hidden-chapter").forEach(el => el.classList.remove("hidden"));
  }
</script>
