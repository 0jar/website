---
import BaseLayout from "@/layouts/BaseLayout.astro";
import T from "@/components/ui/T.astro";
import { getData } from "@/content.config";
import Card from "@/components/ui/Card.astro";
import CardList from "@/components/ui/CardList.astro";
import { projectIcons, projectStatusConfig } from "@/lib/constants";

const lang = Astro.locals?.lang || "en";
const projects = (await getData("projects")).filter((p) => !p.hidden);

const statusGroups = projectStatusConfig
  .map(config => ({
    key: config.key,
    bg: config.bg,
    items: projects.filter((p) => p.status === config.status)
  }))
  .filter((g) => g.items.length > 0);

const categories = Object.keys(projectIcons);

const t = (p: any, field: string) => p.content[lang]?.[field] || p.content.en[field];
---

<BaseLayout title="Projects" description="A collection of my projects and experiments.">
  <div class="container mx-auto px-4 py-8 lg:py-12">
    <div class="max-w-4xl mx-auto">
      <header class="mb-10 text-center">
        <T key="projects.title" tag="h1" class="text-4xl md:text-5xl font-bold mb-4" />
        <T key="projects.description" tag="p" class="text-muted-foreground text-lg mx-auto" />
      </header>

      <div class="flex flex-wrap justify-center gap-2 mb-8" aria-label="Project filters">
        <button class="filter-btn active px-4 py-2 rounded-full border transition-colors" data-filter="all" aria-pressed="true">
          <T key="projects.filters.all" />
        </button>
        {categories.map((cat) => (
          <button class="filter-btn px-4 py-2 rounded-full border transition-colors" data-filter={cat} aria-pressed="false">
            <T key={`projects.categories.${cat}`} />
          </button>
        ))}
      </div>

    {statusGroups.map(({ key, bg, items }) => (
      <section class="mb-12">
        <h2 class="text-2xl font-semibold mb-6 flex items-center gap-2">
          <span class={`w-3 h-3 rounded-full ${bg}`} aria-hidden="true" />
          <T key={`projects.status.${key.replace("-", "")}`} />
        </h2>

        <CardList cols={2}>
          {items.map((p) => {
            const title = t(p, 'title');
            return (
              <article
                class="project-card group perspective"
                data-category={p.category}
                tabindex="0"
                role="button"
                aria-label={`${title} - click to flip`}
                aria-expanded="false"
              >
                <div class="card-inner relative w-full h-[310px] transition-transform duration-700 transform-style-preserve-3d">
                  {/* Front */}
                  <Card as="div" hover={false} padding="lg" class="card-front absolute inset-0 backface-hidden !bg-card/90 backdrop-blur-md flex flex-col shadow-md transition-all duration-300 group-hover:border-primary/50 group-hover:shadow-2xl group-hover:-translate-y-1">
                    <div class="flex items-start justify-between mb-5">
                      <span class="text-4xl filter drop-shadow-md" aria-hidden="true">{projectIcons[p.category]}</span>
                      <div class="flex gap-1.5 flex-wrap justify-end max-w-[65%]">
                        {p.tags.slice(0, 4).map((tag) => (
                          <span class="text-[11px] px-2 py-1 rounded-full bg-secondary text-secondary-foreground font-bold shadow-sm">{tag}</span>
                        ))}
                      </div>
                    </div>
                    <h3 class="text-xl font-bold mb-2 project-title group-hover:text-primary transition-colors">{title}</h3>
                    <p class="text-muted-foreground text-sm flex-1 line-clamp-4 leading-relaxed">{t(p, 'description')}</p>
                    {p.url && (
                      <div class="mt-4">
                        <a href={p.url} target="_blank" rel="noopener noreferrer" class="flex w-full justify-center items-center gap-1.5 px-4 py-2 rounded-lg bg-primary/10 hover:bg-primary/20 text-primary text-sm font-bold transition-colors focus:ring-2 focus:ring-primary focus:outline-none mb-2">
                          <T key="projects.buttons.visit" />
                          <span aria-hidden="true">↗</span>
                          <kbd class="hidden md:inline-block ml-1 border border-primary/30 rounded px-1.5 py-0.5 text-[10px] bg-primary/5 font-sans">Enter</kbd>
                        </a>
                      </div>
                    )}
                    <div class="mt-4 flex items-center justify-between text-xs font-bold text-primary opacity-100 transition-opacity">
                      <div class="flex items-center gap-2">
                        <T key="projects.clickToFlip" />
                        <kbd class="hidden md:inline-block border border-primary/30 rounded px-1.5 py-0.5 text-[10px] bg-primary/5 font-sans">Space</kbd>
                      </div>
                      <span aria-hidden="true" class="transform group-hover:translate-x-1 transition-transform">→</span>
                    </div>
                  </Card>

                  {/* Back */}
                  <Card as="div" hover={false} padding="lg" class="card-back absolute inset-0 backface-hidden flex flex-col rotate-y-180 shadow-xl overflow-y-auto overflow-x-hidden custom-scrollbar">
                    <div class="space-y-5 flex-1">
                      <div>
                        <T key="projects.what" tag="h4" class="text-xs font-bold text-primary/80 mb-2" />
                        <p class="text-sm leading-relaxed text-card-foreground/90">{t(p, 'what')}</p>
                      </div>
                      <div>
                        <T key="projects.learned" tag="h4" class="text-xs font-bold text-primary/80 mb-2" />
                        <p class="text-sm leading-relaxed text-card-foreground/90">{t(p, 'learned')}</p>
                      </div>
                      <div>
                        <T key="projects.why" tag="h4" class="text-xs font-bold text-primary/80 mb-2" />
                        <p class="text-sm leading-relaxed text-card-foreground/90">{t(p, 'why')}</p>
                      </div>
                      {p.url && (
                        <div class="pt-2">
                          <a href={p.url} target="_blank" rel="noopener noreferrer" class="flex w-full justify-center items-center gap-1.5 px-4 py-2 rounded-lg bg-primary/10 hover:bg-primary/20 text-primary text-sm font-bold transition-colors focus:ring-2 focus:ring-primary focus:outline-none">
                            <T key="projects.buttons.visit" />
                            <span aria-hidden="true">↗</span>
                            <kbd class="hidden md:inline-block ml-1 border border-primary/30 rounded px-1.5 py-0.5 text-[10px] bg-primary/5 font-sans">Enter</kbd>
                          </a>
                        </div>
                      )}
                    </div>
                    <div class="mt-6 pt-4 border-t flex items-center justify-between text-xs font-bold text-primary/70 opacity-100 transition-opacity">
                      <T key="projects.cardActions.clickToClose" />
                      <span class="hidden md:inline-flex items-center gap-1 font-sans">
                        <kbd class="border border-primary/30 rounded px-1.5 py-0.5 text-[10px] bg-primary/5">Space</kbd>
                        <span>/</span>
                        <kbd class="border border-primary/30 rounded px-1.5 py-0.5 text-[10px] bg-primary/5">Esc</kbd>
                      </span>
                    </div>
                  </Card>
                </div>
              </article>
            );
          })}
        </CardList>
      </section>
    ))}
    </div>
  </div>
</BaseLayout>

<style>
  .perspective { perspective: 1500px; }
  .transform-style-preserve-3d { transform-style: preserve-3d; }
  .backface-hidden { backface-visibility: hidden; -webkit-backface-visibility: hidden; }
  .rotate-y-180 { transform: rotateY(180deg); }
  .card-inner.flipped { transform: rotateY(180deg); }

  .project-card { outline: none; cursor: pointer; }
  .project-card:focus-visible .card-front { border-color: hsl(var(--primary)); box-shadow: 0 0 0 3px hsl(var(--ring)); }

  .filter-btn { opacity: 0.6; border-color: transparent; cursor: pointer; }
  .filter-btn:hover { opacity: 1; background-color: hsl(var(--secondary)); }
  .filter-btn.active { opacity: 1; background-color: hsl(var(--primary) / 0.1); border-color: hsl(var(--primary)); color: hsl(var(--primary)); }

  .custom-scrollbar::-webkit-scrollbar { width: 5px; }
  .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
  .custom-scrollbar::-webkit-scrollbar-thumb { background: hsl(var(--primary) / 0.3); border-radius: 10px; }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: hsl(var(--primary) / 0.5); }
</style>

<script>
  const cards = document.querySelectorAll<HTMLElement>(".project-card");
  const btns = document.querySelectorAll<HTMLButtonElement>(".filter-btn");

  cards.forEach((card) => {
    const flip = (forceState?: boolean) => {
      const inner = card.querySelector(".card-inner");
      if (!inner) return;
      const isFlipped = typeof forceState === "boolean" ? forceState : !inner.classList.contains("flipped");
      inner.classList.toggle("flipped", isFlipped);
      card.setAttribute("aria-expanded", String(isFlipped));
    };

    card.addEventListener("click", (e) => {
      if ((e.target as HTMLElement).closest('a')) return;
      flip();
    });
    card.addEventListener("keydown", (e) => {
      const isFlipped = card.getAttribute("aria-expanded") === "true";

      if (e.key === "Enter") {
        e.preventDefault();
        const link = card.querySelector("a");
        if (link) {
          link.click();
        } else {
          flip();
        }
        return;
      }

      if (e.key === " ") {
        e.preventDefault();
        flip();
        return;
      }

      if (e.key === "Escape" && isFlipped) {
        e.preventDefault();
        flip(false);
        card.focus();
        return;
      }

      if (["ArrowLeft", "ArrowRight", "ArrowUp", "ArrowDown"].includes(e.key)) {
        if (isFlipped && (e.key === "ArrowUp" || e.key === "ArrowDown")) {
          e.preventDefault();
          const scrollable = card.querySelector(".card-back");
          if (scrollable) {
            scrollable.scrollTop += e.key === "ArrowDown" ? 40 : -40;
          }
          return;
        }

        e.preventDefault();

        if (isFlipped && (e.key === "ArrowLeft" || e.key === "ArrowRight")) {
          flip(false);
        }

        const visible = Array.from(document.querySelectorAll<HTMLElement>(".project-card:not(.hidden)"));
        const idx = visible.indexOf(card);
        if (idx === -1) return;

        const cols = window.innerWidth >= 768 ? 2 : 1;
        let nextIdx = idx;

        if (e.key === "ArrowLeft") nextIdx = idx - 1;
        if (e.key === "ArrowRight") nextIdx = idx + 1;
        if (e.key === "ArrowUp") nextIdx = idx - cols;
        if (e.key === "ArrowDown") nextIdx = idx + cols;

        if (nextIdx >= 0 && nextIdx < visible.length) {
          visible[nextIdx].focus();
        }
      }
    });
  });

  btns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter;

      btns.forEach((b) => {
        b.classList.remove("active");
        b.setAttribute("aria-pressed", "false");
      });

      btn.classList.add("active");
      btn.setAttribute("aria-pressed", "true");

      cards.forEach((card) => {
        const match = filter === "all" || card.dataset.category === filter;
        card.classList.toggle("hidden", !match);
      });
    });
  });
</script>
