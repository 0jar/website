---
import BaseLayout from "@/layouts/BaseLayout.astro";
import T from "@/components/T.astro";
import Card from "@/components/Card.astro";
import CardList from "@/components/CardList.astro";
import { t } from "@/i18n";

const lang = Astro.locals?.lang || "en";

// Auto-scan: discover all tool subpages by globbing index.astro files under /tools/
const toolPages = import.meta.glob("./**/index.astro", { eager: false });
const tools = Object.keys(toolPages)
  .map((path) => path.match(/^\.\/(.*?)\/index\.astro$/)?.[1])
  .filter((slug): slug is string => !!slug)
  .sort();
---

<BaseLayout title={t(lang, "tools.title")} description={t(lang, "tools.description")}>
  <div class="container mx-auto px-4 py-8 lg:py-12">
    <div class="max-w-4xl mx-auto">
      <header class="mb-10 text-center">
        <T key="tools.title" tag="h1" class="text-4xl font-bold mb-4" />
        <T key="tools.description" tag="p" class="text-muted-foreground text-lg mx-auto" />
      </header>

      <CardList cols={2}>
        {tools.map((slug) => (
          <Card as="a"
            href={`/tools/${slug}/`}
            class="group flex flex-col focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
          >
            <T key={`tools.items.${slug}.icon`} tag="span" class="text-3xl mb-3" aria-hidden="true" />
            <T key={`tools.items.${slug}.title`} tag="h2" class="text-xl font-bold mb-2 group-hover:underline" />
            <T key={`tools.items.${slug}.description`} tag="p" class="text-muted-foreground text-sm flex-1" />
          </Card>
        ))}
      </CardList>
    </div>
  </div>
</BaseLayout>
